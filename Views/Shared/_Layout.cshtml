<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CodeArena</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg sticky-top py-3">
        <div class="container">
            <a class="navbar-brand fw-bold fs-3" href="/">
                <i class="bi bi-code-square me-2" style="color: var(--primary);"></i>CodeArena
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-2">
                    <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Problem" ? "active" : "")" href="/Problem">Problems</a></li>
                    <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Contest" ? "active" : "")" href="/Contest">Contests</a></li>
                    <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Ranking" ? "active" : "")" href="/Ranking">Ranking</a></li>
                    <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Submissions" ? "active" : "")" href="/Submissions">Submissions</a></li>
                    <!-- Compiler is accessible only when solving a problem, remove top-level nav link -->
                    @if (User.Identity != null && User.Identity.IsAuthenticated && (User.IsInRole("Admin") || User.IsInRole("Setter")))
                    {
                        <li class="nav-item">
                            <a class="nav-link fw-bold text-danger" href="/Admin/Dashboard">
                                <i class="bi bi-shield-lock-fill me-1"></i> Admin Panel
                            </a>
                        </li>
                    }
                </ul>
                <div class="d-flex gap-3 align-items-center">
                    <button class="theme-toggle" id="themeToggle">
                        <i class="bi bi-sun-fill me-1"></i> <span id="themeText">Light</span>
                    </button>
                    
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        var username = User.Identity.Name;
                        var userFullName = User.FindFirst("FullName")?.Value ?? username;
                        <div class="dropdown">
                            <button class="btn btn-outline-theme dropdown-toggle d-flex align-items-center gap-2" type="button" data-bs-toggle="dropdown">
                                <div class="user-avatar">
                                    @(userFullName?.Substring(0, 1) ?? "U")
                                </div>
                                <span>@username</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="/Auth/Profile"><i class="bi bi-person-circle me-2"></i>My Profile</a></li>
                                <li><a class="dropdown-item" href="#"><i class="bi bi-gear me-2"></i>Settings</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form method="post" action="/Auth/Logout" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i>Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a href="/Auth/Login" class="btn btn-outline-theme px-4 rounded-pill">Log in</a>
                        <a href="/Auth/Signup" class="btn btn-primary px-4 rounded-pill">Sign up</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <div class="main-content">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        
        @RenderBody()
    </div>

    <footer class="site-footer mt-5">
        <div class="footer-gradient-bar"></div>
        <div class="container">
            <!-- Main Footer -->
            <div class="row py-5 gy-4">
                <!-- Brand Column -->
                <div class="col-lg-4 col-md-6">
                    <a class="d-inline-flex align-items-center text-decoration-none mb-3" href="/">
                        <i class="bi bi-code-square fs-2 me-2" style="color: var(--primary);"></i>
                        <span class="fw-bold fs-3" style="color: var(--text-primary);">CodeArena</span>
                    </a>
                    <p class="text-secondary" style="font-size: 0.95rem; line-height: 1.7; max-width: 320px;">
                        A modern online judge & contest platform — practice problems, compete in contests, and sharpen your coding skills.
                    </p>
                    <div class="d-flex gap-2 mt-3">
                        <a href="#" class="footer-social-btn" title="GitHub"><i class="bi bi-github"></i></a>
                        <a href="#" class="footer-social-btn" title="Facebook"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="footer-social-btn" title="LinkedIn"><i class="bi bi-linkedin"></i></a>
                        <a href="#" class="footer-social-btn" title="Twitter / X"><i class="bi bi-twitter-x"></i></a>
                    </div>
                </div>

                <!-- Platform Links -->
                <div class="col-lg-2 col-md-3 col-6">
                    <h6 class="footer-heading">Platform</h6>
                    <ul class="list-unstyled footer-links">
                        <li><a href="/Problem"><i class="bi bi-arrow-right-short me-1"></i>Problems</a></li>
                        <li><a href="/Contest"><i class="bi bi-arrow-right-short me-1"></i>Contests</a></li>
                        <li><a href="/Ranking"><i class="bi bi-arrow-right-short me-1"></i>Ranking</a></li>
                        <li><a href="/Submissions"><i class="bi bi-arrow-right-short me-1"></i>Submissions</a></li>
                    </ul>
                </div>

                <!-- Resources Links -->
                <div class="col-lg-2 col-md-3 col-6">
                    <h6 class="footer-heading">Resources</h6>
                    <ul class="list-unstyled footer-links">
                        <li><a href="#"><i class="bi bi-arrow-right-short me-1"></i>Documentation</a></li>
                        <li><a href="#"><i class="bi bi-arrow-right-short me-1"></i>API</a></li>
                        <li><a href="#"><i class="bi bi-arrow-right-short me-1"></i>FAQ</a></li>
                    </ul>
                </div>

                <!-- Company Links -->
                <div class="col-lg-2 col-md-3 col-6">
                    <h6 class="footer-heading">Company</h6>
                    <ul class="list-unstyled footer-links">
                        <li><a href="/Home/Team"><i class="bi bi-arrow-right-short me-1"></i>Our Team</a></li>
                        <li><a href="#"><i class="bi bi-arrow-right-short me-1"></i>About Us</a></li>
                        <li><a href="#"><i class="bi bi-arrow-right-short me-1"></i>Contact</a></li>
                    </ul>
                </div>

                <!-- Contact Info -->
                <div class="col-lg-2 col-md-3 col-6">
                    <h6 class="footer-heading">Contact</h6>
                    <ul class="list-unstyled footer-links">
                        <li><a href="mailto:support@codearena.com"><i class="bi bi-envelope me-1"></i>Email Us</a></li>
                        <li><a href="/Home/Team"><i class="bi bi-people me-1"></i>Meet the Team</a></li>
                    </ul>
                </div>
            </div>

            <!-- Bottom Bar -->
            <div class="footer-bottom">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
                    <p class="mb-0 text-secondary" style="font-size: 0.875rem;">
                        © 2026 <strong>CodeArena</strong>. Built with <i class="bi bi-heart-fill text-danger"></i> by
                        <a href="/Home/Team" class="text-decoration-none" style="color: var(--primary);">Team CodeArena</a>
                    </p>
                    <div class="d-flex gap-3">
                        <a href="#" class="text-secondary text-decoration-none footer-bottom-link" style="font-size: 0.85rem;">Privacy Policy</a>
                        <a href="#" class="text-secondary text-decoration-none footer-bottom-link" style="font-size: 0.85rem;">Terms of Service</a>
                    </div>
                </div>
            </div>
        </div>
    </footer>
    <!-- In _Layout.cshtml, replace the script section at the bottom with: -->
<!-- In _Layout.cshtml, replace the entire script section with: -->

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Single source of truth for theme management
    (function() {
        // Theme management
        const toggleBtn = document.getElementById('themeToggle');
        const themeText = document.getElementById('themeText');
        const body = document.body;

        function setTheme(theme) {
            if (theme === 'dark') {
                body.classList.add('dark');
                if (themeText) themeText.innerText = 'Dark';
                if (toggleBtn) toggleBtn.innerHTML = '<i class="bi bi-moon-stars-fill me-1"></i> Dark';
                localStorage.setItem('theme', 'dark');
            } else {
                body.classList.remove('dark');
                if (themeText) themeText.innerText = 'Light';
                if (toggleBtn) toggleBtn.innerHTML = '<i class="bi bi-sun-fill me-1"></i> Light';
                localStorage.setItem('theme', 'light');
            }
            
            // Dispatch custom event for other components
            document.dispatchEvent(new CustomEvent('themeChanged', { 
                detail: { theme: theme } 
            }));
        }

        // Initialize theme from localStorage
        const savedTheme = localStorage.getItem('theme') || 'light';
        setTheme(savedTheme);

        // Theme toggle click handler
        if (toggleBtn) {
            toggleBtn.addEventListener('click', function(e) {
                e.preventDefault();
                const newTheme = body.classList.contains('dark') ? 'light' : 'dark';
                setTheme(newTheme);
            });
        }

        // Bootstrap components initialization
        function initBootstrapComponents() {
            // Initialize all dropdowns
            document.querySelectorAll('.dropdown-toggle').forEach(function(dropdownToggle) {
                // Check if it's already initialized
                if (!dropdownToggle.getAttribute('aria-expanded')) {
                    try {
                        new bootstrap.Dropdown(dropdownToggle);
                    } catch (e) {
                        // Ignore if already initialized
                    }
                }
            });

            // Initialize tooltips if any
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function(tooltipTrigger) {
                try {
                    new bootstrap.Tooltip(tooltipTrigger);
                } catch (e) {}
            });

            // Initialize popovers if any
            document.querySelectorAll('[data-bs-toggle="popover"]').forEach(function(popoverTrigger) {
                try {
                    new bootstrap.Popover(popoverTrigger);
                } catch (e) {}
            });
        }

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', function() {
            initBootstrapComponents();
        });

        // Watch for dynamically added elements
        const observer = new MutationObserver(function(mutations) {
            let shouldReinit = false;
            
            mutations.forEach(function(mutation) {
                if (mutation.addedNodes.length) {
                    for (let node of mutation.addedNodes) {
                        if (node.nodeType === 1) { // Element node
                            if (node.classList && (
                                node.classList.contains('dropdown-toggle') ||
                                node.querySelectorAll('.dropdown-toggle').length > 0
                            )) {
                                shouldReinit = true;
                                break;
                            }
                        }
                    }
                }
            });
            
            if (shouldReinit) {
                setTimeout(initBootstrapComponents, 100);
            }
        });

        observer.observe(document.body, {
            childList: true,
            subtree: true
        });
    })();
</script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
