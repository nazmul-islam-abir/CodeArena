<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Control Panel</title>
    
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <!-- Core Styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <style>
        .admin-sidebar {
            min-height: calc(100vh - 60px);
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            border-right: 1px solid var(--glass-border);
            padding: 1.5rem 1rem;
        }
        
        .admin-nav-link {
            color: var(--text-secondary);
            padding: 0.75rem 1rem;
            border-radius: 8px;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 0.5rem;
            transition: all 0.2s;
            font-weight: 500;
            text-decoration: none;
        }
        
        .admin-nav-link:hover, .admin-nav-link.active {
            background: rgba(99, 102, 241, 0.1);
            color: #6366f1;
        }
        
        .admin-nav-link i {
            font-size: 1.2rem;
        }
    </style>
</head>
<body class="dark">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold text-gradient" href="/">
                <i class="bi bi-code-slash me-2"></i>CodeArena
            </a>
            <div class="d-flex align-items-center gap-3">
                @if (User.IsInRole("Admin"))
                {
                    <span class="badge bg-danger"><i class="bi bi-shield-lock-fill me-1"></i> Admin Mode</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark"><i class="bi bi-shield-lock-fill me-1"></i> Setter Mode</span>
                }
                <a href="/" class="btn btn-outline-theme btn-sm">Return to Site</a>
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-md-3 col-lg-2 px-0 admin-sidebar d-none d-md-block">
                <div class="nav flex-column">
                    <a href="/Admin/Dashboard" class="admin-nav-link @(Context.Request.Path.StartsWithSegments("/Admin/Dashboard") || Context.Request.Path == "/Admin" ? "active" : "")">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/Users" class="admin-nav-link @(Context.Request.Path.StartsWithSegments("/Admin/Users") ? "active" : "")">
                            <i class="bi bi-people"></i> Users Control
                        </a>
                    }
                    <a href="/Admin/Problems" class="admin-nav-link @(Context.Request.Path.StartsWithSegments("/Admin/Problems") ? "active" : "")">
                        <i class="bi bi-file-earmark-code"></i> Problem Control
                    </a>
                    <a href="/Admin/Contests" class="admin-nav-link @(Context.Request.Path.StartsWithSegments("/Admin/Contests") ? "active" : "")">
                        <i class="bi bi-trophy"></i> Contest Control
                    </a>
                    <a href="/Admin/Submissions" class="admin-nav-link @(Context.Request.Path.StartsWithSegments("/Admin/Submissions") ? "active" : "")">
                        <i class="bi bi-clock-history"></i> Submissions
                    </a>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-md-9 col-lg-10 p-4 main-content">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
