@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    var stats = ViewBag.Stats;
}

<div class="mb-4">
    <h2 class="fw-bold text-gradient">Admin Dashboard</h2>
    <p class="text-secondary">Overview of system statistics and quick actions.</p>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-3">
        <div class="card glass-card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted text-uppercase mb-2">Total Users</h6>
                        <h2 class="fw-bold mb-0">@stats.TotalUsers</h2>
                    </div>
                    <div class="bg-primary bg-opacity-10 text-primary rounded p-3">
                        <i class="bi bi-people fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-3">
        <div class="card glass-card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted text-uppercase mb-2">Total Problems</h6>
                        <h2 class="fw-bold mb-0">@stats.TotalProblems</h2>
                    </div>
                    <div class="bg-success bg-opacity-10 text-success rounded p-3">
                        <i class="bi bi-file-earmark-code fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card glass-card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted text-uppercase mb-2">Contests</h6>
                        <h2 class="fw-bold mb-0">@stats.TotalContests</h2>
                    </div>
                    <div class="bg-warning bg-opacity-10 text-warning rounded p-3">
                        <i class="bi bi-trophy fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card glass-card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted text-uppercase mb-2">Submissions</h6>
                        <h2 class="fw-bold mb-0">@stats.TotalSubmissions</h2>
                    </div>
                    <div class="bg-info bg-opacity-10 text-info rounded p-3">
                        <i class="bi bi-clock-history fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <h4 class="fw-bold mb-4">Quick Links</h4>
        <div class="d-flex gap-3 flex-wrap">
            <a href="/Admin/Users" class="btn btn-outline-primary"><i class="bi bi-person-gear me-2"></i>Manage Users</a>
            <a href="/Admin/Problems" class="btn btn-outline-success"><i class="bi bi-journal-code me-2"></i>Manage Problems</a>
            <a href="/Admin/Problems/Create" class="btn btn-success"><i class="bi bi-plus-circle me-2"></i>New Problem</a>
            <a href="/Contest/Create" class="btn btn-warning text-dark"><i class="bi bi-plus-circle me-2"></i>New Contest</a>
            <a href="/Admin/CodeforcesImport" class="btn btn-outline-info"><i class="bi bi-cloud-arrow-down me-2"></i>Import from Codeforces</a>
        </div>
    </div>
</div>
