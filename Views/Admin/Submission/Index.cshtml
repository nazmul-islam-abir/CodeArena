@model IEnumerable<MyMvcApp.Models.Submission>
@{
    ViewData["Title"] = "Submission Control";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-gradient mb-0">Submission Control</h2>
</div>

<div class="card glass-card overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>User</th>
                    <th>Problem</th>
                    <th>Language</th>
                    <th>Verdict</th>
                    <th>Time / Memory</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var sub in Model)
                {
                    <tr>
                        <td><span class="text-secondary">#@sub.Id</span></td>
                        <td><div class="fw-bold">@sub.UserName</div></td>
                        <td>@sub.ProblemTitle</td>
                        <td><span class="badge bg-secondary">@sub.LanguageName</span></td>
                        <td>
                            <span class="badge-custom verdict-@(sub.Verdict?.ToLower() ?? "ce")">
                                @sub.Verdict
                            </span>
                        </td>
                        <td>
                            <div class="small">
                                <span class="me-2"><i class="bi bi-clock"></i> @sub.ExecutionTime s</span>
                                <span><i class="bi bi-cpu"></i> @(sub.MemoryUsed / 1024) MB</span>
                            </div>
                        </td>
                        <td>@sub.SubmittedAt.ToLocalTime().ToString("MMM dd, HH:mm")</td>
                        <td>
                            <form asp-action="Rejudge" asp-route-id="@sub.Id" method="post" style="display:inline;">
                                <button type="submit" class="btn btn-sm btn-outline-warning" title="Rejudge"><i class="bi bi-arrow-repeat"></i> Rejudge</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
