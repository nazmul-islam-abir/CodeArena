@{
    ViewData["Title"] = "Import from Codeforces";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <h2 class="fw-bold mb-4"><i class="bi bi-cloud-download me-2 text-primary"></i>Import from Codeforces</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Import All Problems -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-grid-3x3-gap-fill me-2"></i>Import All Problems</h5>
                </div>
                <div class="card-body">
                    <p class="text-secondary">Import problems from the entire Codeforces problemset.</p>
                    <p><strong>Note:</strong> This may take a few minutes due to API rate limits.</p>
                    
                    <form asp-action="ImportAll" asp-controller="CodeforcesImport" asp-area="Admin" method="post">
                        <div class="mb-3">
                            <label class="form-label">Number of problems to import (max 1000)</label>
                            <input type="number" name="limit" class="form-control" value="500" min="10" max="1000" />
                        </div>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-cloud-download me-2"></i>Import Problems
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Import by Contest -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-trophy-fill me-2"></i>Import by Contest</h5>
                </div>
                <div class="card-body">
                    <p class="text-secondary">Import all problems from a specific Codeforces contest.</p>
                    
                    <form asp-action="ImportContest" asp-controller="CodeforcesImport" asp-area="Admin" method="post">
                        <div class="mb-3">
                            <label class="form-label">Contest ID</label>
                            <input type="number" name="contestId" class="form-control" placeholder="e.g., 1851" required />
                            <small class="text-secondary">You can find contest ID in the URL: codeforces.com/contest/<strong>1851</strong></small>
                        </div>
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-cloud-download me-2"></i>Import Contest
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Import by Rating -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-warning">
                    <h5 class="mb-0"><i class="bi bi-star-fill me-2"></i>Import by Rating</h5>
                </div>
                <div class="card-body">
                    <p class="text-secondary">Import problems within a specific rating range.</p>
                    
                    <form asp-action="ImportByRating" asp-controller="CodeforcesImport" asp-area="Admin" method="post">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Min Rating</label>
                                <input type="number" name="minRating" class="form-control" value="800" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Max Rating</label>
                                <input type="number" name="maxRating" class="form-control" value="3500" />
                            </div>
                        </div>
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-cloud-download me-2"></i>Import by Rating
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Search and Import -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="bi bi-search me-2"></i>Search and Import</h5>
                </div>
                <div class="card-body">
                    <p class="text-secondary">Search for specific problems to import.</p>
                    
                    <div class="mb-3">
                        <label class="form-label">Search Problems</label>
                        <input type="text" id="searchQuery" class="form-control" placeholder="Search by name or tag..." />
                    </div>
                    <div id="searchResults" class="mt-3" style="max-height: 300px; overflow-y: auto;">
                        <p class="text-secondary">Type at least 3 characters to search...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- API Info Card -->
    <div class="card mt-4">
        <div class="card-header">
            <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Codeforces API Information</h5>
        </div>
        <div class="card-body">
            <p><strong>API Key:</strong> <code>@ViewBag.MaskedApiKey</code></p>
            <p><strong>Rate Limit:</strong> 1 request per 2 seconds</p>
            <p><strong>Documentation:</strong> <a href="https://codeforces.com/apiHelp" target="_blank">https://codeforces.com/apiHelp</a></p>
        </div>
    </div>
</div>

<script>
    let searchTimeout;
    const searchInput = document.getElementById('searchQuery');
    const resultsDiv = document.getElementById('searchResults');

    searchInput.addEventListener('input', function() {
        clearTimeout(searchTimeout);
        const query = this.value.trim();
        
        if (query.length < 3) {
            resultsDiv.innerHTML = '<p class="text-secondary">Type at least 3 characters to search...</p>';
            return;
        }

        searchTimeout = setTimeout(() => {
            resultsDiv.innerHTML = '<p class="text-secondary">Searching...</p>';
            
            fetch(`/Admin/Codeforces/search?query=${encodeURIComponent(query)}`)
                .then(response => response.json())
                .then(data => {
                    if (data.error) {
                        resultsDiv.innerHTML = `<p class="text-danger">${data.error}</p>`;
                    } else if (data.length === 0) {
                        resultsDiv.innerHTML = '<p class="text-secondary">No problems found</p>';
                    } else {
                        let html = '<div class="list-group">';
                        data.forEach(problem => {
                            html += `
                                <div class="list-group-item list-group-item-action">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <strong>${problem.name || 'Unnamed'}</strong>
                                            <br>
                                            <small class="text-secondary">
                                                ${problem.contestId || '?'}${problem.index || ''} | 
                                                Rating: ${problem.rating || 'N/A'} | 
                                                Solved: ${problem.solvedCount || 0}
                                            </small>
                                            <div class="mt-1">
                                                ${problem.tags ? problem.tags.slice(0, 3).map(t => 
                                                    `<span class="badge bg-secondary me-1">${t}</span>`
                                                ).join('') : ''}
                                            </div>
                                        </div>
                                        <a href="${problem.problemUrl || '#'}" target="_blank" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-box-arrow-up-right"></i>
                                        </a>
                                    </div>
                                </div>
                            `;
                        });
                        html += '</div>';
                        resultsDiv.innerHTML = html;
                    }
                })
                .catch(error => {
                    resultsDiv.innerHTML = `<p class="text-danger">Error: ${error.message}</p>`;
                });
        }, 500);
    });
</script>

<style>
    .card {
        background-color: var(--bg-card);
        border: 1px solid var(--border-light);
        border-radius: 16px;
        transition: transform 0.2s;
    }

    .card:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 30px -10px rgba(0,100,200,0.15);
    }

    .card-header {
        background-color: transparent;
        border-bottom: 1px solid var(--border-light);
        padding: 1.25rem 1.5rem;
        font-weight: 600;
    }

    .card-header.bg-primary {
        background: linear-gradient(135deg, #2563eb, #1e40af) !important;
    }

    .card-header.bg-success {
        background: linear-gradient(135deg, #10b981, #059669) !important;
    }

    .card-header.bg-warning {
        background: linear-gradient(135deg, #f59e0b, #d97706) !important;
    }

    .card-header.bg-info {
        background: linear-gradient(135deg, #3b82f6, #2563eb) !important;
    }

    .list-group-item {
        background-color: var(--bg-card);
        border-color: var(--border-light);
        color: var(--text-primary);
    }

    .list-group-item:hover {
        background-color: var(--primary-light);
    }

    .badge {
        font-weight: 500;
        padding: 0.3rem 0.6rem;
    }

    code {
        background-color: var(--bg-body);
        color: var(--text-primary);
        padding: 0.2rem 0.4rem;
        border-radius: 4px;
        font-size: 0.9rem;
    }

    .btn-primary {
        background: linear-gradient(135deg, #2563eb, #1e40af);
        border: none;
    }

    .btn-success {
        background: linear-gradient(135deg, #10b981, #059669);
        border: none;
    }

    .btn-warning {
        background: linear-gradient(135deg, #f59e0b, #d97706);
        border: none;
        color: white;
    }

    .form-control {
        background-color: var(--input-bg);
        color: var(--text-primary);
        border-color: var(--border-light);
    }

    .form-control:focus {
        background-color: var(--input-bg);
        color: var(--text-primary);
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
    }

    body.dark .card-header.bg-warning {
        color: white;
    }

    body.dark .list-group-item {
        background-color: var(--bg-card);
    }
</style>