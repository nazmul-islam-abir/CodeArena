@model IEnumerable<MyMvcApp.Models.Problem>
@{
    ViewData["Title"] = "Manage Problems";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-6 fw-bold text-gradient">Manage Problems</h1>
        <a asp-action="Create" class="btn btn-primary shadow-sm"><i class="bi bi-plus-circle me-1"></i> Create New Problem</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light border-bottom"><tr><th class="ps-4">Title</th><th>Category</th><th>Difficulty</th><th>Visibility</th><th>Limits</th><th class="text-end pe-4">Actions</th></tr></thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4"><div class="fw-bold">@item.Title</div><small class="text-muted text-uppercase" style="font-size:0.7rem;">ID: @item.Id</small></td>
                            <td><span class="badge bg-light text-dark border">@item.Category</span></td>
                            <td><span class="badge @(item.Difficulty == 1 ? "bg-success" : item.Difficulty == 2 ? "bg-warning text-dark" : "bg-danger")">@item.DifficultyText</span></td>
                            <td>
                                @if (item.IsPrivate)
                                {
                                    <span class="badge bg-dark"><i class="bi bi-lock-fill me-1"></i>Private</span>
                                }
                                else
                                {
                                    <span class="badge bg-success"><i class="bi bi-globe me-1"></i>Public</span>
                                }
                            </td>
                            <td><div class="small"><span class="me-2"><i class="bi bi-clock me-1"></i> @item.TimeLimit s</span><span><i class="bi bi-cpu me-1"></i> @(item.MemoryLimit / 1024) MB</span></div></td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <a asp-action="TestCases" asp-route-problemId="@item.Id" class="btn btn-sm btn-outline-info" title="Manage Test Cases"><i class="bi bi-list-check"></i> <span class="d-none d-xl-inline">Test Cases</span></a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Edit Problem"><i class="bi bi-pencil"></i></a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Are you sure? This will delete all associated test cases.');" style="display:inline;">@Html.AntiForgeryToken()<button type="submit" class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button></form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="6" class="text-center py-5 text-muted"><i class="bi bi-inbox display-4 d-block mb-3"></i>No problems found. Create your first problem to get started!</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>