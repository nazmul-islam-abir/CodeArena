@model MyMvcApp.Models.Problem

@{
    ViewData["Title"] = "Create Problem";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Admin</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Problems</a></li>
                    <li class="breadcrumb-item active">Create</li>
                </ol>
            </nav>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-primary text-white py-3 px-4">
                    <h3 class="card-title mb-0 h5"><i class="bi bi-plus-lg me-2"></i>Create New Problem</h3>
                </div>
                <div class="card-body p-4 p-md-5">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger shadow-sm mb-4">
                            <h6 class="fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i>Please correct the following errors:</h6>
                            <div asp-validation-summary="All" class="small"></div>
                        </div>
                    }
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <div class="row g-4">
                            <!-- Basic Info -->
                            <div class="col-md-8">
                                <div class="form-floating mb-3">
                                    <input asp-for="Title" class="form-control" placeholder="Problem Title" required />
                                    <label asp-for="Title"></label>
                                    <span asp-validation-for="Title" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Description" class="form-label fw-bold small"></label>
                                    <textarea asp-for="Description" class="form-control" rows="10" placeholder="Describe the problem, input format, output format..."></textarea>
                                    <span asp-validation-for="Description" class="text-danger"></span>
                                </div>
                            </div>

                            <!-- Sidebar settings -->
                            <div class="col-md-4">
                                <div class="p-3 bg-light rounded-4 border">
                                    <h5 class="h6 mb-3 fw-bold"><i class="bi bi-gear me-2"></i>Settings</h5>
                                    
                                    <div class="mb-3">
                                        <label asp-for="Difficulty" class="form-label small fw-bold"></label>
                                        <select asp-for="Difficulty" class="form-select">
                                            <option value="1">Easy</option>
                                            <option value="2">Medium</option>
                                            <option value="3">Hard</option>
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Category" class="form-label small fw-bold"></label>
                                        <input asp-for="Category" class="form-control" placeholder="e.g. Dynamic Programming" />
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="Points" class="form-label small fw-bold"></label>
                                        <input asp-for="Points" class="form-control" type="number" value="100" />
                                    </div>

                                    <hr />

                                    <div class="mb-3">
                                        <label asp-for="TimeLimit" class="form-label small fw-bold">Time Limit (Seconds)</label>
                                        <input asp-for="TimeLimit" class="form-control" type="number" step="1" value="1" />
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="MemoryLimit" class="form-label small fw-bold">Memory Limit (KB)</label>
                                        <input asp-for="MemoryLimit" class="form-control" type="number" step="1" value="256000" />
                                    </div>
                                </div>
                            </div>

                            <!-- Details Sections -->
                            <div class="col-md-12">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label asp-for="InputFormat" class="form-label fw-bold small"></label>
                                        <textarea asp-for="InputFormat" class="form-control" rows="3"></textarea>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="OutputFormat" class="form-label fw-bold small"></label>
                                        <textarea asp-for="OutputFormat" class="form-control" rows="3"></textarea>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="SampleInput" class="form-label fw-bold small"></label>
                                        <textarea asp-for="SampleInput" class="form-control" rows="5"></textarea>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="SampleOutput" class="form-label fw-bold small"></label>
                                        <textarea asp-for="SampleOutput" class="form-control" rows="5"></textarea>
                                    </div>
                                    <div class="col-md-12">
                                        <label asp-for="Constraints" class="form-label fw-bold small"></label>
                                        <textarea asp-for="Constraints" class="form-control" rows="2"></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-5 d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-5 py-2 shadow-sm">
                                <i class="bi bi-save me-2"></i>Save Problem
                            </button>
                            <a asp-action="Index" class="btn btn-light px-4 py-2 border">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
