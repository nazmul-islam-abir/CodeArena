@{
    ViewData["Title"] = "Compiler";
    Layout = "~/Views/Shared/_Layout.cshtml";

    int selectedLanguage = ViewBag.SelectedLanguage ?? 54;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CodeArena · Compiler</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/codemirror.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/theme/dracula.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/theme/eclipse.min.css">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .CodeMirror {
            height: 480px;
            font-family: 'Fira Code', 'Consolas', monospace;
            font-size: 14px;
            line-height: 1.6;
            border-radius: 0 0 8px 8px;
            border: none;
        }

        .editor-toolbar {
            background: var(--card-bg, #f8fafc);
            border-bottom: 1px solid var(--border-color, #e2e8f0);
            padding: 0.5rem 1rem;
            border-radius: 8px 8px 0 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .output-window {
            background: var(--code-bg, #f8fafc);
            border-radius: 0 0 8px 8px;
            padding: 1rem;
            font-family: 'Consolas', monospace;
            min-height: 150px;
            max-height: 350px;
            overflow-y: auto;
            white-space: pre-wrap;
            font-size: 13px;
        }

        .badge-verdict {
            padding: 0.4rem 0.9rem;
            border-radius: 20px;
            font-weight: 600;
            font-size: 0.85rem;
        }
        .badge-ac  { background-color: #10b981; color: white; }
        .badge-wa  { background-color: #ef4444; color: white; }
        .badge-tle { background-color: #f59e0b; color: white; }
        .badge-mle { background-color: #8b5cf6; color: white; }
        .badge-ce  { background-color: #6b7280; color: white; }
        .badge-re  { background-color: #dc2626; color: white; }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 0.75rem;
            margin-top: 1rem;
        }

        .stat-item {
            background: var(--code-bg, #f1f5f9);
            padding: 0.6rem 0.8rem;
            border-radius: 8px;
            text-align: center;
        }

        .btn-submit {
            background-color: #10b981;
            color: white;
            padding: 0.55rem 1.5rem;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.2s;
        }
        .btn-submit:hover:not(:disabled) {
            background-color: #059669;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
        }
        .btn-submit:disabled {
            opacity: 0.7;
            cursor: not-allowed;
        }

        .language-selector {
            min-width: 200px;
        }
    </style>
</head>
<body>

    <div class="container py-4">

        @* Page Header *@
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
            <div>
                <h2 class="fw-bold mb-1"><i class="bi bi-code-slash me-2 text-primary"></i>Code Compiler</h2>
                <p class="text-secondary mb-0">Write, run, and submit your solution</p>
            </div>
            @if (ViewBag.ProblemTitle != null)
            {
                <a href="/Problem/@ViewBag.ProblemId" class="btn btn-outline-primary">
                    <i class="bi bi-arrow-left me-2"></i>Back to Problem
                </a>
            }
            else
            {
                <a href="/Problem" class="btn btn-outline-primary">
                    <i class="bi bi-list-task me-2"></i>Problems
                </a>
            }
        </div>

        @* Problem Context Banner *@
        @if (ViewBag.ProblemTitle != null)
        {
            <div class="card mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                        <div>
                            <h5 class="fw-bold mb-1"><i class="bi bi-puzzle-fill me-2 text-primary"></i>@ViewBag.ProblemTitle</h5>
                            @if (ViewBag.ProblemDescription != null)
                            {
                                <p class="text-secondary mb-2 small">@ViewBag.ProblemDescription</p>
                            }
                            <div class="d-flex flex-wrap gap-2">
                                @if (ViewBag.ProblemSampleInput != null)
                                {
                                    <span class="badge bg-secondary">Sample Input: @ViewBag.ProblemSampleInput</span>
                                }
                                @if (ViewBag.ProblemSampleOutput != null)
                                {
                                    <span class="badge bg-secondary">Expected Output: @ViewBag.ProblemSampleOutput</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* Code Editor Card *@
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2 py-3">
                <h5 class="fw-bold mb-0"><i class="bi bi-file-code me-2 text-primary"></i>Code Editor</h5>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-outline-secondary" id="resetCode" title="Reset code">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Reset
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" id="formatCode" title="Auto-indent">
                        <i class="bi bi-braces me-1"></i>Format
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" id="fullscreen" title="Fullscreen">
                        <i class="bi bi-arrows-fullscreen"></i>
                    </button>
                </div>
            </div>

            <div class="editor-toolbar">
                <form method="post" id="compilerForm" class="w-100">
                    @if (ViewBag.ProblemId != null)
                    {
                        <input type="hidden" name="problemId" value="@ViewBag.ProblemId" />
                    }
                    @if (ViewBag.ContestId != null)
                    {
                        <input type="hidden" name="contestId" value="@ViewBag.ContestId" />
                    }
                    @{
                        string defaultCode = @"#include <iostream>
using namespace std;

int main() {
    int a, b;
    cin >> a >> b;
    cout << a + b << endl;
    
    return 0;
}";
                        string codeToDisplay = ViewBag.SubmittedCode ?? defaultCode;
                    }
                    <textarea name="sourceCode" id="codeEditor" class="d-none">@codeToDisplay</textarea>

                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 w-100">
                        <select name="languageId" id="languageSelect" class="form-select form-select-sm language-selector">
                            <optgroup label="C/C++">
                                <option value="54" selected="@(selectedLanguage == 54)">C++ (GCC 9.2.0)</option>
                                <option value="52" selected="@(selectedLanguage == 52)">C++ (GCC 7.4.0)</option>
                                <option value="76" selected="@(selectedLanguage == 76)">C++ (Clang 7.0.1)</option>
                                <option value="50" selected="@(selectedLanguage == 50)">C (GCC 9.2.0)</option>
                                <option value="49" selected="@(selectedLanguage == 49)">C (GCC 8.3.0)</option>
                                <option value="75" selected="@(selectedLanguage == 75)">C (Clang 7.0.1)</option>
                            </optgroup>
                            <optgroup label="Python">
                                <option value="71" selected="@(selectedLanguage == 71)">Python 3.8.1</option>
                                <option value="70" selected="@(selectedLanguage == 70)">Python 2.7.17</option>
                            </optgroup>
                            <optgroup label="Java">
                                <option value="62" selected="@(selectedLanguage == 62)">Java (OpenJDK 13)</option>
                                <option value="27" selected="@(selectedLanguage == 27)">Java (OpenJDK 8)</option>
                            </optgroup>
                            <optgroup label="Web Languages">
                                <option value="63" selected="@(selectedLanguage == 63)">JavaScript (Node.js 12.14)</option>
                                <option value="74" selected="@(selectedLanguage == 74)">TypeScript 3.7.4</option>
                                <option value="68" selected="@(selectedLanguage == 68)">PHP 7.4.1</option>
                            </optgroup>
                            <optgroup label=".NET">
                                <option value="51" selected="@(selectedLanguage == 51)">C# (Mono 6.6.0)</option>
                                <option value="88" selected="@(selectedLanguage == 88)">.NET Core 3.1</option>
                            </optgroup>
                            <optgroup label="Other">
                                <option value="60" selected="@(selectedLanguage == 60)">Go 1.13.5</option>
                                <option value="73" selected="@(selectedLanguage == 73)">Rust 1.40.0</option>
                                <option value="72" selected="@(selectedLanguage == 72)">Ruby 2.7.0</option>
                                <option value="45" selected="@(selectedLanguage == 45)">Assembly (NASM 2.14)</option>
                                <option value="46" selected="@(selectedLanguage == 46)">Bash 5.0.0</option>
                                <option value="56" selected="@(selectedLanguage == 56)">Swift 5.2.3</option>
                                <option value="57" selected="@(selectedLanguage == 57)">Kotlin 1.3.70</option>
                                <option value="55" selected="@(selectedLanguage == 55)">Dart 2.8.4</option>
                                <option value="58" selected="@(selectedLanguage == 58)">R 3.6.1</option>
                                <option value="59" selected="@(selectedLanguage == 59)">Perl 5.26.1</option>
                            </optgroup>
                        </select>

                        <div class="d-flex gap-2 ms-auto">
                            <button type="submit" name="action" value="runSample" class="btn btn-outline-primary btn-sm px-3" id="runSampleBtn">
                                <span id="runSampleText"><i class="bi bi-bug me-1"></i>Run Sample</span>
                                <span id="runSampleSpinner" class="spinner-border spinner-border-sm d-none" role="status"></span>
                            </button>
                            <button type="submit" name="action" value="submit" class="btn-submit" id="runBtn">
                                <span id="runText"><i class="bi bi-play-fill me-1"></i>Submit</span>
                                <span id="runSpinner" class="spinner-border spinner-border-sm d-none" role="status"></span>
                            </button>
                        </div>
                    </div>
                </form>
            </div>

            <div class="card-body p-0">
                @* CodeMirror mounts here *@
            </div>
        </div>

        @* Output Section *@
        @if (ViewBag.Output != null)
        {
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center py-3">
                    <h5 class="fw-bold mb-0"><i class="bi bi-terminal me-2 text-success"></i>Output</h5>
                    @{
                        int statusCode = ViewBag.StatusCode ?? 0;
                    }
                    @if (statusCode == 3)
                    {
                        <span class="badge-verdict badge-ac">Accepted ✓</span>
                    }
                    else if (statusCode == 4)
                    {
                        <span class="badge-verdict badge-wa">Wrong Answer ✗</span>
                    }
                    else if (statusCode == 5)
                    {
                        <span class="badge-verdict badge-tle">Time Limit Exceeded ⏰</span>
                    }
                    else if (statusCode == 6)
                    {
                        <span class="badge-verdict badge-mle">Memory Limit Exceeded 💾</span>
                    }
                    else if (statusCode == 7)
                    {
                        <span class="badge-verdict badge-re">Runtime Error ⚠️</span>
                    }
                    else if (statusCode == 8)
                    {
                        <span class="badge-verdict badge-ce">Compilation Error 🔧</span>
                    }
                </div>

                <div class="card-body">
                    <div class="output-window">
                        <pre class="mb-0">@ViewBag.Output</pre>
                    </div>

                    @if (ViewBag.ExpectedOutput != null)
                    {
                        <div class="mt-3">
                            <h6 class="fw-bold text-secondary mb-2">Expected Output</h6>
                            <div class="output-window">
                                <pre class="mb-0">@ViewBag.ExpectedOutput</pre>
                            </div>
                        </div>
                    }

                    @if (ViewBag.Time != null || ViewBag.Memory != null)
                    {
                        <div class="stats-grid">
                            @if (ViewBag.Time != null)
                            {
                                <div class="stat-item">
                                    <small class="text-secondary d-block">Execution Time</small>
                                    <strong>@ViewBag.Time</strong>
                                </div>
                            }
                            @if (ViewBag.Memory != null)
                            {
                                <div class="stat-item">
                                    <small class="text-secondary d-block">Memory Used</small>
                                    <strong>@ViewBag.Memory</strong>
                                </div>
                            }
                            <div class="stat-item">
                                <small class="text-secondary d-block">Status</small>
                                <strong>@(ViewBag.StatusDescription ?? "Completed")</strong>
                            </div>
                        </div>
                    }

                    @if (statusCode >= 5 && statusCode <= 8)
                    {
                        <div class="alert alert-danger mt-3 mb-0">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <strong>@(ViewBag.StatusDescription):</strong> @ViewBag.Output
                        </div>
                    }
                    else if (statusCode == 3)
                    {
                        <div class="alert alert-success mt-3 mb-0">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            <strong>Success!</strong> Program executed successfully.
                        </div>
                    }
                </div>
            </div>
        }

    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/codemirror.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/mode/clike/clike.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/mode/python/python.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/mode/javascript/javascript.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/mode/php/php.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/mode/ruby/ruby.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/mode/go/go.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.2/mode/rust/rust.min.js"></script>
    <script>
        // Initialize CodeMirror — attach to the card body
        const textarea = document.getElementById('codeEditor');
        const cardBody = document.querySelector('.card-body');

        let editor = CodeMirror.fromTextArea(textarea, {
            lineNumbers: true,
            autoCloseBrackets: true,
            matchBrackets: true,
            indentUnit: 4,
            tabSize: 4,
            lineWrapping: true,
            theme: document.body.classList.contains('dark') ? 'dracula' : 'eclipse',
            mode: 'text/x-c++src',
            extraKeys: {
                'Ctrl-Space': 'autocomplete',
                'Tab': 'indentMore',
                'Shift-Tab': 'indentLess'
            }
        });

        // Language mode mapping
        const langSelect = document.getElementById('languageSelect');
        langSelect.addEventListener('change', function () {
            updateLanguageMode(this.value);
        });

        function updateLanguageMode(langId) {
            const modeMap = {
                71: 'text/x-python', 70: 'text/x-python',
                62: 'text/x-java',   27: 'text/x-java',
                63: 'javascript',    74: 'javascript',
                68: 'application/x-httpd-php',
                51: 'text/x-csharp', 88: 'text/x-csharp',
                60: 'text/x-go',
                73: 'text/x-rustsrc',
                72: 'text/x-ruby',
                45: 'text/x-asm'
            };
            editor.setOption('mode', modeMap[langId] || 'text/x-c++src');
        }

        // Sync editor theme with layout dark mode toggle
        function syncEditorTheme() {
            if (editor) {
                editor.setOption('theme', document.body.classList.contains('dark') ? 'dracula' : 'eclipse');
            }
        }
        syncEditorTheme();
        new MutationObserver(() => syncEditorTheme()).observe(document.body, { attributes: true });

        // Reset to default code for selected language
        document.getElementById('resetCode').addEventListener('click', () => {
            const langId = langSelect.value;
            if (langId == 71 || langId == 70) {
                editor.setValue(`# Python 3\nprint("Hello, CodeArena!")\n\na, b = map(int, input().split())\nprint("Sum:", a + b)`);
            } else if (langId == 62 || langId == 27) {
                editor.setValue(`import java.util.Scanner;\n\npublic class Main {\n    public static void main(String[] args) {\n        Scanner sc = new Scanner(System.in);\n        int a = sc.nextInt(), b = sc.nextInt();\n        System.out.println(a + b);\n    }\n}`);
            } else {
                editor.setValue(`#include <iostream>\nusing namespace std;\n\nint main() {\n    int a, b;\n    cin >> a >> b;\n    cout << a + b << endl;\n    return 0;\n}`);
            }
        });

        // Format (auto-indent)
        document.getElementById('formatCode').addEventListener('click', () => {
            editor.autoIndentRange({ line: 0, ch: 0 }, { line: editor.lineCount() - 1 });
        });

        // Fullscreen toggle
        document.getElementById('fullscreen').addEventListener('click', () => {
            const el = document.querySelector('.CodeMirror');
            if (document.fullscreenElement) document.exitFullscreen();
            else el.requestFullscreen();
        });

        // Form submit spinners
        document.getElementById('compilerForm').addEventListener('submit', function (e) {
            const submitter = e.submitter;
            if (submitter && submitter.name === 'action') {
                const hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = 'action';
                hidden.value = submitter.value;
                this.appendChild(hidden);
            }

            if (submitter && submitter.id === 'runSampleBtn') {
                document.getElementById('runSampleBtn').disabled = true;
                document.getElementById('runSampleText').classList.add('d-none');
                document.getElementById('runSampleSpinner').classList.remove('d-none');
                document.getElementById('runBtn').disabled = true;
            } else {
                document.getElementById('runBtn').disabled = true;
                document.getElementById('runText').classList.add('d-none');
                document.getElementById('runSpinner').classList.remove('d-none');
                const rsBtn = document.getElementById('runSampleBtn');
                if (rsBtn) rsBtn.disabled = true;
            }
        });

        @if (ViewBag.Output != null)
        {
            <text>
            // Re-enable buttons after result
            document.getElementById('runBtn').disabled = false;
            document.getElementById('runText').classList.remove('d-none');
            document.getElementById('runSpinner').classList.add('d-none');
            const rsBtn = document.getElementById('runSampleBtn');
            if (rsBtn) {
                rsBtn.disabled = false;
                document.getElementById('runSampleText').classList.remove('d-none');
                document.getElementById('runSampleSpinner').classList.add('d-none');
            }
            </text>
        }

        // Re-init Bootstrap dropdowns after page load
        document.addEventListener('DOMContentLoaded', function () {
            setTimeout(function () {
                document.querySelectorAll('.dropdown-toggle').forEach(el => {
                    if (!el.getAttribute('aria-expanded')) new bootstrap.Dropdown(el);
                });
            }, 500);
        });
    </script>
</body>
</html>
