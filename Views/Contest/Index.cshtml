<!-- Views/Contest/Index.cshtml - Updated -->
@model IEnumerable<MyMvcApp.Models.Contest>
@{
    ViewData["Title"] = "Contests";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold"><i class="bi bi-trophy-fill me-2 text-warning"></i>Coding Contests</h2>
            <p class="text-secondary">Compete, solve problems, and climb the leaderboard</p>
        </div>
        <div class="d-flex gap-2">
            <div class="dropdown">
                <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-funnel me-1"></i> Filter
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item filter-btn" data-status="all" href="#">All Contests</a></li>
                    <li><a class="dropdown-item filter-btn" data-status="Active" href="#">Active</a></li>
                    <li><a class="dropdown-item filter-btn" data-status="Upcoming" href="#">Upcoming</a></li>
                    <li><a class="dropdown-item filter-btn" data-status="Ended" href="#">Ended</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item filter-btn" data-status="registered" href="#">My Contests</a></li>
                </ul>
            </div>
            @if (User.IsInRole("Admin"))
            {
                <a href="/Contest/Create" class="btn btn-primary">
                    <i class="bi bi-plus-circle me-2"></i>Create Contest
                </a>
            }
        </div>
    </div>

    <div class="row g-4" id="contestContainer">
        @foreach (var contest in Model)
        {
            <div class="col-md-6 col-lg-4 contest-card" data-status="@contest.Status" data-registered="@contest.IsRegistered.ToString().ToLower()">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="d-flex gap-2">
                                <span class="badge @(contest.Status == "Active" ? "bg-success" : contest.Status == "Upcoming" ? "bg-warning" : "bg-secondary")">
                                    @contest.Status
                                </span>
                                @if (contest.IsPrivate)
                                {
                                    <span class="badge bg-dark"><i class="bi bi-lock-fill me-1"></i>Private</span>
                                }
                            </div>

                        </div>
                        <h5 class="fw-bold mb-2">@contest.Title</h5>
                        <p class="text-secondary small mb-3">@(contest.Description.Length > 100 ? contest.Description.Substring(0, 100) + "..." : contest.Description)</p>
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <small class="text-secondary">Start Time:</small>
                                <small>@contest.StartTime.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</small>
                            </div>
                            <div class="d-flex justify-content-between mb-1">
                                <small class="text-secondary">Duration:</small>
                                <small>@contest.Duration</small>
                            </div>
                            <div class="d-flex justify-content-between">
                                <small class="text-secondary">Participants:</small>
                                <small>@contest.ParticipantCount</small>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <a href="/Contest/@contest.Id" class="btn btn-primary flex-grow-1">
                                View Details
                            </a>
                            @if (contest.IsRegistered && contest.Status == "Active")
                            {
                                <a href="/Contest/@contest.Id/Ranking" class="btn btn-outline-warning" title="View Ranking">
                                    <i class="bi bi-trophy"></i>
                                </a>
                            }
                            @if (!string.IsNullOrEmpty(contest.ContestLink))
                            {
                                <button class="btn btn-outline-secondary" onclick="copyLink('@contest.ContestLink')" title="Copy join link">
                                    <i class="bi bi-link-45deg"></i>
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-calendar-x fs-1 text-secondary"></i>
            <h4 class="mt-3 text-secondary">No Contests Available</h4>
            @if (User.IsInRole("Admin"))
            {
                <a href="/Contest/Create" class="btn btn-primary mt-3">Create Your First Contest</a>
            }
        </div>
    }
</div>

<script>
    function copyLink(link) {
        const fullLink = window.location.origin + "/Contest/Join?link=" + link;
        navigator.clipboard.writeText(fullLink);
        alert("Contest link copied to clipboard!");
    }
    
    // Filter contests
    document.querySelectorAll('.filter-btn').forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            const status = this.dataset.status;
            
            document.querySelectorAll('.contest-card').forEach(card => {
                if (status === 'all') {
                    card.style.display = '';
                } else if (status === 'registered') {
                    card.style.display = card.dataset.registered === 'true' ? '' : 'none';
                } else {
                    card.style.display = card.dataset.status === status ? '' : 'none';
                }
            });
        });
    });
</script>

<style>
    .contest-card {
        transition: all 0.2s;
    }
</style>