@model MyMvcApp.Models.ContestViewModel
@{
    ViewData["Title"] = "Create Contest";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="fw-bold mb-0"><i class="bi bi-plus-circle me-2"></i>Create New Contest</h4>
                </div>
                <div class="card-body">
                    <form method="post" action="/Contest/Create">
                        @Html.AntiForgeryToken()
                        
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Contest Title <span class="text-danger">*</span></label>
                            <input asp-for="Contest.Title" class="form-control" required placeholder="e.g., Weekly Contest #1" />
                            <span asp-validation-for="Contest.Title" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Description <span class="text-danger">*</span></label>
                            <textarea asp-for="Contest.Description" class="form-control" rows="4" required placeholder="Describe the contest..."></textarea>
                            <span asp-validation-for="Contest.Description" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Organizer</label>
                            <input asp-for="Contest.Organizer" class="form-control" value="CodeArena" />
                        </div>
                        
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-bold">Start Date & Time <span class="text-danger">*</span></label>
                                <input asp-for="Contest.StartTime" type="datetime-local" class="form-control" required />
                                <span asp-validation-for="Contest.StartTime" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-bold">Duration (Hours)</label>
                                <select id="durationHours" class="form-select">
                                    @for (int h = 0; h <= 24; h++)
                                    {
                                        if (h == 2)
                                        {
                                            <option value="@h" selected>@h hrs</option>
                                        }
                                        else
                                        {
                                            <option value="@h">@h hrs</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-bold">Duration (Minutes)</label>
                                <select id="durationMinutes" class="form-select">
                                    @for (int m = 0; m <= 55; m += 5)
                                    {
                                        <option value="@m">@m mins</option>
                                    }
                                </select>
                            </div>
                            <input type="hidden" asp-for="Contest.Duration" id="durationHidden" value="2 hours 0 minutes" />
                        </div>
                        


                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-check form-switch">
                                    <input asp-for="Contest.IsPrivate" class="form-check-input" type="checkbox" id="isPrivateSwitch">
                                    <label class="form-check-label fw-bold" for="isPrivateSwitch">Private Contest</label>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3" id="passwordField" style="display: none;">
                                <label class="form-label fw-bold">Contest Password</label>
                                <input asp-for="Contest.Password" type="password" class="form-control" placeholder="Enter password for private contest" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Rules (Optional)</label>
                            <textarea asp-for="Contest.Rules" class="form-control" rows="3" placeholder="Contest rules, penalties, etc..."></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Problem IDs (comma separated) <span class="text-danger">*</span></label>
                            <input type="text" name="problemIds" class="form-control" placeholder="e.g., 1, 2, 5, 10" required />
                            <div class="form-text">Enter the IDs of the problems you want to include in this contest.</div>
                        </div>
                        
                        <hr />
                        
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-check-circle me-2"></i>Create Contest
                            </button>
                            <a href="/Contest" class="btn btn-outline-secondary px-4">
                                <i class="bi bi-x-circle me-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('isPrivateSwitch').addEventListener('change', function() {
        document.getElementById('passwordField').style.display = this.checked ? 'block' : 'none';
    });

    function syncDuration() {
        var h = parseInt(document.getElementById('durationHours').value);
        var m = parseInt(document.getElementById('durationMinutes').value);
        if (h === 0 && m === 0) { m = 5; document.getElementById('durationMinutes').value = '5'; }
        document.getElementById('durationHidden').value = h + ' hours ' + m + ' minutes';
    }
    document.getElementById('durationHours').addEventListener('change', syncDuration);
    document.getElementById('durationMinutes').addEventListener('change', syncDuration);
    syncDuration();
</script>

<style>
    .card {
        background-color: var(--bg-card);
        border: 1px solid var(--border-light);
        border-radius: 16px;
    }
    
    .form-control, .form-select {
        background-color: var(--input-bg);
        color: var(--text-primary);
        border-color: var(--border-light);
    }
    
        .form-control:focus, .form-select:focus {
            background-color: var(--input-bg);
            color: var(--text-primary);
            border-color: var(--primary);
            box-shadow: 0 0 0 0.2rem rgba(2, 132, 199, 0.25);
        }
</style>