<!-- Views/Contest/Details.cshtml - Complete clean version -->
@model MyMvcApp.Models.Contest
@{
    ViewData["Title"] = Model.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var problems = ViewBag.Problems as List<MyMvcApp.Models.ContestProblem>;
    var solvedStatus = ViewBag.SolvedStatus as Dictionary<string, bool> ?? new Dictionary<string, bool>();
    var isActive = Model.Status == "Active";
    var isUpcoming = Model.Status == "Upcoming";
    var isEnded = Model.Status == "Ended";
}

<div class="container py-4">
    <!-- Contest Header -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                <div class="flex-grow-1">
                    <div class="d-flex align-items-center gap-3 mb-2 flex-wrap">
                        <h1 class="fw-bold mb-0">@Model.Title</h1>
                        <span class="badge @(isActive ? "bg-success" : isUpcoming ? "bg-warning" : "bg-secondary") fs-6 px-3 py-2">
                            @Model.Status
                        </span>
                        @if (Model.IsPrivate)
                        {
                            <span class="badge bg-dark fs-6 px-3 py-2"><i class="bi bi-lock-fill me-1"></i>Private</span>
                        }
                    </div>
                    <p class="text-secondary mb-3">@Model.Description</p>
                    <div class="d-flex flex-wrap gap-3 mb-3">
                        <span class="badge-custom"><i class="bi bi-person-circle me-1"></i> @Model.Organizer</span>
                        <span class="badge-custom"><i class="bi bi-calendar-event me-1"></i> @Model.StartTime.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</span>
                        <span class="badge-custom"><i class="bi bi-hourglass-split me-1"></i> @Model.Duration</span>
                        <span class="badge-custom"><i class="bi bi-people-fill me-1"></i> @Model.ParticipantCount participants</span>
                        <span class="badge-custom"><i class="bi bi-puzzle-fill me-1"></i> @Model.ProblemCount problems</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Rules))
                    {
                        <div class="alert alert-info mt-2 mb-0">
                            <i class="bi bi-info-circle-fill me-2"></i>
                            <strong>Rules:</strong> @Model.Rules
                        </div>
                    }
                </div>
                <div class="text-end">
                    @if (isActive)
                    {
                        <div class="countdown-timer" data-end="@Model.EndTime.ToLocalTime().ToString("yyyy-MM-ddTHH:mm:ss")">
                            <div class="display-6 fw-bold text-primary">--:--:--</div>
                            <small class="text-secondary">Time Remaining</small>
                        </div>
                    }
                    else if (isUpcoming)
                    {
                        <div class="countdown-timer" data-end="@Model.StartTime.ToLocalTime().ToString("yyyy-MM-ddTHH:mm:ss")" data-is-upcoming="true">
                            <div class="display-6 fw-bold text-warning">--:--:--</div>
                            <small class="text-secondary">Starts in</small>
                        </div>
                    }
                    else
                    {
                        <span class="badge bg-secondary fs-5 px-4 py-3">Contest Finished</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="d-flex gap-2 mb-4 flex-wrap">
        @if (!Model.IsRegistered && !isEnded)
        {
            if (Model.IsPrivate && !string.IsNullOrEmpty(Model.Password))
            {
                <button type="button" class="btn btn-success btn-lg" data-bs-toggle="modal" data-bs-target="#passwordModal">
                    <i class="bi bi-key me-2"></i>Register with Password
                </button>
            }
            else
            {
                <form method="post" action="/Contest/Register">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="contestId" value="@Model.Id" />
                    <button type="submit" class="btn btn-success btn-lg">
                        <i class="bi bi-check-circle me-2"></i>Register for Contest
                    </button>
                </form>
            }
        }
        else if (Model.IsRegistered && !isEnded)
        {
            <form method="post" action="/Contest/Unregister">
                @Html.AntiForgeryToken()
                <input type="hidden" name="contestId" value="@Model.Id" />
                <button type="submit" class="btn btn-outline-danger btn-lg">
                    <i class="bi bi-x-circle me-2"></i>Unregister
                </button>
            </form>
        }

        @if (Model.IsRegistered || isEnded)
        {
            <a href="/Contest/@Model.Id/Submissions" class="btn btn-outline-primary btn-lg">
                <i class="bi bi-clock-history me-2"></i>My Submissions
            </a>
            
            <a href="/Contest/@Model.Id/Ranking" class="btn btn-outline-warning btn-lg">
                <i class="bi bi-trophy me-2"></i>Leaderboard
            </a>
        }

        @if ((User.IsInRole("Admin") || User.IsInRole("Setter")))
        {
            <a href="/Contest/Edit/@Model.Id" class="btn btn-outline-secondary btn-lg">
                <i class="bi bi-pencil me-2"></i>Edit
            </a>
            <form method="post" action="/Contest/ToggleFreeze/@Model.Id" style="display: inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn @(Model.IsFrozen ? "btn-warning" : "btn-outline-info") btn-lg">
                    <i class="bi @(Model.IsFrozen ? "bi-snow" : "bi-thermometer-half") me-2"></i>
                    @(Model.IsFrozen ? "Unfreeze Standings" : "Freeze Standings")
                </button>
            </form>
            <a href="/Contest/@Model.Id/Registrations" class="btn btn-outline-info btn-lg">
                <i class="bi bi-people me-2"></i>Registrations
            </a>
        }
    </div>

    <!-- Problems List -->
    <div class="card">
        <div class="card-header">
            <h4 class="fw-bold mb-0"><i class="bi bi-list-task me-2 text-primary"></i>Problems</h4>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th style="width: 80px">#</th>
                            <th>Problem Name</th>
                            <th style="width: 100px">Points</th>
                            <th style="width: 120px">Status</th>
                            <th style="width: 150px">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (problems != null)
                        {
                            foreach (var cp in problems)
                            {
                                var isSolved = solvedStatus.GetValueOrDefault(cp.Letter, false);
                                <tr>
                                    <td class="fw-bold text-primary fs-4">@cp.Letter</td>
                                    <td>
                                        <div class="fw-medium">@cp.Problem?.Title</div>
                                        @if (cp.CustomTitle != null)
                                        {
                                            <small class="text-secondary">@cp.CustomTitle</small>
                                        }
                                    </td>
                                    <td><span class="badge bg-info">@cp.Points pts</span></td>
                                    <td>
                                        @if (isSolved && isActive && Model.IsRegistered)
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check-circle-fill me-1"></i>Solved</span>
                                        }
                                        else if (isSolved && isEnded)
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check-circle-fill me-1"></i>Solved (Practice)</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Unsolved</span>
                                        }
                                    </td>
                                    <td>
                                        @if (isActive && Model.IsRegistered)
                                        {
                                            <a href="/Contest/@Model.Id/Problem/@cp.Letter" class="btn btn-sm btn-primary">
                                                @(isSolved ? "Resubmit" : "Solve") <i class="bi bi-arrow-right ms-1"></i>
                                            </a>
                                        }
                                        else if (isEnded)
                                        {
                                            <a href="/Contest/@Model.Id/Problem/@cp.Letter" class="btn btn-sm btn-outline-secondary">
                                                Practice <i class="bi bi-arrow-right ms-1"></i>
                                            </a>
                                        }
                                        else if (!Model.IsRegistered && isActive)
                                        {
                                            <button class="btn btn-sm btn-secondary" disabled>
                                                Register to Solve
                                            </button>
                                        }
                                        else if (isUpcoming)
                                        {
                                            <span class="text-secondary">Starts soon</span>
                                        }
                                        else
                                        {
                                            <a href="/Problem/@cp.ProblemId" class="btn btn-sm btn-outline-primary">
                                                View <i class="bi bi-eye ms-1"></i>
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Password Modal for Private Contests -->
<div class="modal fade" id="passwordModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" action="/Contest/Register">
                @Html.AntiForgeryToken()
                <input type="hidden" name="contestId" value="@Model.Id" />
                <div class="modal-header">
                    <h5 class="modal-title">Private Contest Registration</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>This contest requires a password to join.</p>
                    <div class="mb-3">
                        <label class="form-label">Contest Password</label>
                        <input type="password" name="password" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Register</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .badge-custom {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        background-color: var(--bg-body);
        border: 1px solid var(--border-light);
        border-radius: 30px;
        font-size: 0.9rem;
        color: var(--text-primary);
    }

    .countdown-timer .display-6 {
        font-family: 'Monaco', 'Consolas', monospace;
        font-weight: 700;
    }

    .table tbody tr:hover {
        background-color: var(--table-row-hover);
    }
</style>

<script>
    function updateCountdowns() {
        document.querySelectorAll('.countdown-timer').forEach(function(timer) {
            var endTime = new Date(timer.dataset.end).getTime();
            var now = new Date().getTime();
            var distance = endTime - now;

            var display = timer.querySelector('.display-6');
            if (!display) return;

            if (distance <= 0) {
                if (timer.dataset.isUpcoming === 'true' && !timer.dataset.reloaded) {
                    timer.dataset.reloaded = 'true';
                    setTimeout(() => location.reload(), 1000);
                }
                
                display.innerHTML = "00:00:00";
                display.classList.remove('text-primary', 'text-warning');
                display.classList.add('text-secondary');
                var smallText = timer.querySelector('small');
                if (smallText) smallText.textContent = timer.dataset.isUpcoming === 'true' ? "Contest Started" : "Contest Ended";
            } else {
                var hours = Math.floor(distance / (1000 * 60 * 60));
                var minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                var seconds = Math.floor((distance % (1000 * 60)) / 1000);
                display.innerHTML = hours.toString().padStart(2, '0') + ':' + minutes.toString().padStart(2, '0') + ':' + seconds.toString().padStart(2, '0');
            }
        });
    }

    updateCountdowns();
    setInterval(updateCountdowns, 1000);
</script>
