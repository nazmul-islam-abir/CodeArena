@model MyMvcApp.Models.Contest
@{
    ViewData["Title"] = @Model.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var problems = ViewBag.Problems as List<MyMvcApp.Models.ContestProblem>;
    var isActive = Model.Status == "Active";
    var isUpcoming = Model.Status == "Upcoming";
    var isEnded = Model.Status == "Ended";
}

<div class="container py-4">
    <!-- Contest Header -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h1 class="fw-bold mb-2">@Model.Title</h1>
                    <p class="text-secondary mb-3">@Model.Description</p>
                    <div class="d-flex flex-wrap gap-3 mb-3">
                        <span class="badge-custom"><i class="bi bi-person-circle me-1"></i> @Model.Organizer</span>
                        <span class="badge-custom"><i class="bi bi-calendar-event me-1"></i> @Model.StartTime.ToString("MMM dd, yyyy HH:mm")</span>
                        <span class="badge-custom"><i class="bi bi-hourglass-split me-1"></i> @Model.Duration</span>
                        <span class="badge-custom"><i class="bi bi-people-fill me-1"></i> @Model.ParticipantCount participants</span>
                    </div>
                </div>
                <div class="text-end">
                    @if (isActive)
                    {
                        <div class="countdown-timer" data-end="@Model.EndTime.ToString("yyyy-MM-ddTHH:mm:ss")">
                            <div class="display-6 fw-bold text-primary">--:--:--</div>
                            <small class="text-secondary">Time Remaining</small>
                        </div>
                    }
                    else if (isUpcoming)
                    {
                        <div class="countdown-timer" data-end="@Model.StartTime.ToString("yyyy-MM-ddTHH:mm:ss")">
                            <div class="display-6 fw-bold text-warning">--:--:--</div>
                            <small class="text-secondary">Starts in</small>
                        </div>
                    }
                    else
                    {
                        <span class="badge bg-secondary fs-5">Contest Finished</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="d-flex gap-2 mb-4 flex-wrap">
        @if (!Model.IsRegistered && !isEnded)
        {
            <form method="post" action="/Contest/Register">
                <input type="hidden" name="contestId" value="@Model.Id" />
                <button type="submit" class="btn btn-success btn-lg">
                    <i class="bi bi-check-circle me-2"></i>Register for Contest
                </button>
            </form>
        }
        else if (Model.IsRegistered && !isEnded)
        {
            <form method="post" action="/Contest/Unregister">
                <input type="hidden" name="contestId" value="@Model.Id" />
                <button type="submit" class="btn btn-outline-danger btn-lg">
                    <i class="bi bi-x-circle me-2"></i>Unregister
                </button>
            </form>
        }

        @if (Model.IsRegistered || isEnded)
        {
            <a href="/Contest/@Model.Id/Submissions" class="btn btn-outline-primary btn-lg">
                <i class="bi bi-clock-history me-2"></i>My Submissions
            </a>
            
            <a href="/Contest/@Model.Id/Ranking" class="btn btn-outline-warning btn-lg">
                <i class="bi bi-trophy me-2"></i>Ranking
            </a>
        }

        @if (User.IsInRole("Admin"))
        {
            <a href="/Contest/Edit/@Model.Id" class="btn btn-outline-secondary btn-lg">
                <i class="bi bi-pencil me-2"></i>Edit
            </a>
            <form method="post" action="/Contest/ToggleFreeze/@Model.Id" style="display: inline;">
                <button type="submit" class="btn @(Model.IsFrozen ? "btn-warning" : "btn-outline-info") btn-lg">
                    <i class="bi @(Model.IsFrozen ? "bi-snow" : "bi-thermometer-half") me-2"></i>
                    @(Model.IsFrozen ? "Unfreeze" : "Freeze") Standings
                </button>
            </form>
        }
    </div>

    <!-- Problems List -->
    <div class="card">
        <div class="card-header">
            <h4 class="fw-bold mb-0"><i class="bi bi-list-task me-2 text-primary"></i>Problems</h4>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th style="width: 80px">#</th>
                            <th>Problem Name</th>
                            <th style="width: 100px">Points</th>
                            <th style="width: 150px">Action</th>
                        </thead>
                        <tbody>
                            @if (problems != null)
                            {
                                var letter = 'A';
                                foreach (var cp in problems)
                                {
                                    <tr>
                                        <td class="fw-bold text-primary">@letter</td>
                                        <td>
                                            <a href="/Contest/@Model.Id/Problem/@letter" class="fw-medium" style="color: var(--text-primary); text-decoration: none;">
                                                @cp.Problem?.Title
                                            </a>
                                        </td>
                                        <td>@cp.Points pts</td>
                                        <td>
                                            @if (isActive && Model.IsRegistered)
                                            {
                                                <a href="/Contest/@Model.Id/Problem/@letter" class="btn btn-sm btn-primary">
                                                    Solve <i class="bi bi-arrow-right ms-1"></i>
                                                </a>
                                            }
                                            else if (isEnded)
                                            {
                                                <a href="/Contest/@Model.Id/Problem/@letter" class="btn btn-sm btn-outline-secondary">
                                                    Practice <i class="bi bi-arrow-right ms-1"></i>
                                                </a>
                                            }
                                            else if (!Model.IsRegistered && isActive)
                                            {
                                                <button class="btn btn-sm btn-secondary" disabled>
                                                    Register to Solve
                                                </button>
                                            }
                                            else if (isUpcoming)
                                            {
                                                <span class="text-secondary">Starts soon</span>
                                            }
                                        </td>
                                    </tr>
                                    letter++;
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script>
        function updateCountdowns() {
            document.querySelectorAll('.countdown-timer').forEach(timer => {
                const endTime = new Date(timer.dataset.end).getTime();
                const now = new Date().getTime();
                const distance = endTime - now;

                if (distance < 0) {
                    const display = timer.querySelector('.display-6');
                    if (display) {
                        display.innerHTML = "00:00:00";
                        display.classList.remove('text-primary', 'text-warning');
                        display.classList.add('text-secondary');
                    }
                } else {
                    const hours = Math.floor(distance / (1000 * 60 * 60));
                    const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                    const seconds = Math.floor((distance % (1000 * 60)) / 1000);
                
                    const display = timer.querySelector('.display-6');
                    if (display) {
                        display.innerHTML = `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
                    }
                }
            });
        }

        updateCountdowns();
        setInterval(updateCountdowns, 1000);
    </script>

    <style>
        .badge-custom {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 14px;
            background-color: var(--bg-body);
            border: 1px solid var(--border-light);
            border-radius: 30px;
            font-size: 0.9rem;
            color: var(--text-primary);
        }

        .card {
            background-color: var(--bg-card);
            border: 1px solid var(--border-light);
            border-radius: 16px;
        }

        .card-header {
            background-color: transparent;
            border-bottom: 1px solid var(--border-light);
            padding: 1.25rem 1.5rem;
        }

        .table {
            color: var(--text-primary) !important;
        }

            .table thead th {
                background-color: var(--table-header-bg, var(--bg-body));
                color: var(--text-primary);
                border-bottom-color: var(--border-light);
                font-weight: 600;
            }

            .table tbody tr:hover {
                background-color: var(--table-row-hover, var(--primary-light));
            }

            .table td, .table th {
                border-color: var(--border-light);
                color: var(--text-primary);
                vertical-align: middle;
            }

        .countdown-timer .display-6 {
            font-family: 'Monaco', 'Consolas', monospace;
            font-weight: 700;
        }
    </style>