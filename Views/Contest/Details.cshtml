@model MyMvcApp.Models.Contest
@{
    Layout = null;
    var problems = ViewBag.Problems as List<MyMvcApp.Models.ContestProblem>;
    var leaderboard = ViewBag.Leaderboard as List<MyMvcApp.Models.ContestLeaderboardEntry>;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CodeArena · @Model.Title</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-body: #f8fafc;
            --bg-card: #ffffff;
            --text-primary: #0f172a;
            --text-secondary: #334155;
            --border-light: #e2e8f0;
            --navbar-bg: #ffffffcc;
            --footer-bg: #eef2f6;
            --primary: #0284c7;
            --primary-light: #e0f2fe;
            --success: #10b981;
        }
        body.dark {
            --bg-body: #0b1120;
            --bg-card: #1e293b;
            --text-primary: #f1f5f9;
            --text-secondary: #cbd5e1;
            --border-light: #334155;
            --navbar-bg: #1e293be6;
            --footer-bg: #0f172a;
            --primary: #38bdf8;
            --primary-light: #1e3a5f;
        }
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-primary);
            transition: all 0.2s ease;
        }
        .navbar {
            background-color: var(--navbar-bg) !important;
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border-light);
        }
        .navbar-brand, .nav-link {
            color: var(--text-primary) !important;
        }
        .theme-toggle {
            background: transparent;
            border: 1px solid var(--border-light);
            color: var(--text-primary);
            padding: 0.4rem 1rem;
            border-radius: 60px;
            cursor: pointer;
        }
        .card {
            background-color: var(--bg-card);
            border: 1px solid var(--border-light);
            border-radius: 16px;
        }
        .countdown-large {
            font-size: 2.5rem;
            font-weight: 700;
            font-family: monospace;
            color: var(--primary);
        }
        .problem-item {
            padding: 1rem;
            border-bottom: 1px solid var(--border-light);
            transition: background-color 0.2s;
        }
        .problem-item:hover {
            background-color: var(--primary-light);
        }
        .footer {
            background-color: var(--footer-bg);
            border-top: 1px solid var(--border-light);
        }
        .share-link {
            background: var(--bg-body);
            padding: 0.75rem;
            border-radius: 8px;
            border: 1px dashed var(--border-light);
            font-family: monospace;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg sticky-top py-3">
        <div class="container">
            <a class="navbar-brand fw-bold fs-3" href="/">
                <i class="bi bi-code-square me-2" style="color: var(--primary);"></i>CodeArena
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-2">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Problem">Problems</a></li>
                    <li class="nav-item"><a class="nav-link active fw-bold" href="/Contest">Contests</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Ranking">Ranking</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Compiler">Compiler</a></li>
                </ul>
                <div class="d-flex gap-3 align-items-center">
                    <button class="theme-toggle" id="themeToggle">
                        <i class="bi bi-sun-fill me-1"></i> <span id="themeText">Light</span>
                    </button>
                    <a href="/Auth/Login" class="btn btn-outline-theme px-4 rounded-pill">Log in</a>
                    <a href="/Auth/Signup" class="btn btn-primary px-4 rounded-pill">Sign up</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container py-4">
        <!-- Back Button -->
        <a href="/Contest" class="btn btn-outline-theme mb-4">
            <i class="bi bi-arrow-left me-2"></i>Back to Contests
        </a>

        <!-- Contest Header -->
        <div class="card p-4 mb-4">
            <div class="row">
                <div class="col-md-8">
                    <h2 class="fw-bold">@Model.Title</h2>
                    <p class="text-secondary">@Model.Description</p>
                    
                    <div class="row mt-4">
                        <div class="col-md-4">
                            <small class="text-secondary">Organizer</small>
                            <div><i class="bi bi-person-circle me-2"></i>@Model.Organizer</div>
                        </div>
                        <div class="col-md-4">
                            <small class="text-secondary">Start Time</small>
                            <div><i class="bi bi-calendar-event me-2"></i>@Model.StartTime.ToString("MMM dd, yyyy HH:mm")</div>
                        </div>
                        <div class="col-md-4">
                            <small class="text-secondary">Duration</small>
                            <div><i class="bi bi-clock me-2"></i>@Model.Duration</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 text-end">
                    @if (Model.Status == "Active")
                    {
                        <div>
                            <small class="text-secondary">Time Remaining</small>
                            <div class="countdown-large" data-end="@Model.EndTime.ToString("yyyy-MM-ddTHH:mm:ss")">
                                Calculating...
                            </div>
                        </div>
                    }
                    else if (Model.Status == "Upcoming")
                    {
                        <div class="mt-3">
                            <span class="badge bg-info p-3">Starts in @((Model.StartTime - DateTime.Now).Days) days</span>
                        </div>
                    }
                    else
                    {
                        <div class="mt-3">
                            <span class="badge bg-secondary p-3">Contest Ended</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="d-flex gap-3 mb-4">
            @if (Model.IsRegistered)
            {
                <form method="post" action="/Contest/Unregister">
                    <input type="hidden" name="contestId" value="@Model.Id" />
                    <button type="submit" class="btn btn-outline-danger btn-lg">
                        <i class="bi bi-x-circle me-2"></i>Unregister
                    </button>
                </form>
            }
            else if (Model.Status != "Ended")
            {
                <form method="post" action="/Contest/Register">
                    <input type="hidden" name="contestId" value="@Model.Id" />
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-check-circle me-2"></i>Register Now
                    </button>
                </form>
            }
            
            @if (Model.Status == "Active" && Model.IsRegistered)
            {
                <a href="/Compiler" class="btn btn-success btn-lg">
                    <i class="bi bi-play-circle me-2"></i>Enter Contest
                </a>
            }
            
            <button class="btn btn-outline-theme btn-lg" onclick="copyContestLink()">
                <i class="bi bi-share me-2"></i>Share Link
            </button>
        </div>

        <!-- Share Link -->
        <div class="share-link mb-4" id="contestLink">
            https://codearena.dev/contest/join/@Model.ContestLink
        </div>

        <!-- Problems and Leaderboard -->
        <div class="row">
            <div class="col-md-7">
                <div class="card p-4">
                    <h4 class="fw-bold mb-3"><i class="bi bi-list-task me-2 text-primary"></i>Problems</h4>
                    @if (problems != null)
                    {
                        @foreach (var problem in problems)
                        {
                            <div class="problem-item d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1">@problem.Title</h6>
                                    <div>
                                        <span class="badge bg-secondary me-2">@problem.Difficulty</span>
                                        <small class="text-secondary">@problem.Points pts</small>
                                    </div>
                                </div>
                                <div class="text-end">
                                    <div><small class="text-success">@problem.SolvedCount solved</small></div>
                                    @if (Model.Status == "Active" && Model.IsRegistered)
                                    {
                                        <a href="/Compiler" class="btn btn-sm btn-outline-primary mt-2">Solve</a>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="col-md-5">
                <div class="card p-4">
                    <h4 class="fw-bold mb-3"><i class="bi bi-trophy-fill me-2 text-warning"></i>Leaderboard</h4>
                    @if (leaderboard != null)
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Rank</th>
                                        <th>User</th>
                                        <th>Solved</th>
                                        <th>Points</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var entry in leaderboard)
                                    {
                                        <tr>
                                            <td>
                                                @if (entry.Rank == 1)
                                                {
                                                    <span class="text-warning">🥇</span>
                                                }
                                                else if (entry.Rank == 2)
                                                {
                                                    <span class="text-secondary">🥈</span>
                                                }
                                                else if (entry.Rank == 3)
                                                {
                                                    <span class="text-bronze">🥉</span>
                                                }
                                                else
                                                {
                                                    @entry.Rank
                                                }
                                            </td>
                                            <td>@entry.UserName</td>
                                            <td>@entry.SolvedCount</td>
                                            <td><strong>@entry.TotalPoints</strong></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Stats -->
        <div class="row mt-4">
            <div class="col-md-3">
                <div class="card p-3 text-center">
                    <h3 class="fw-bold text-primary">@Model.ParticipantCount</h3>
                    <small class="text-secondary">Participants</small>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card p-3 text-center">
                    <h3 class="fw-bold text-primary">@Model.ProblemCount</h3>
                    <small class="text-secondary">Problems</small>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card p-3 text-center">
                    <h3 class="fw-bold text-primary">@(leaderboard?.Max(l => l.TotalPoints) ?? 0)</h3>
                    <small class="text-secondary">Highest Score</small>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card p-3 text-center">
                    <h3 class="fw-bold text-primary">@Model.Duration</h3>
                    <small class="text-secondary">Duration</small>
                </div>
            </div>
        </div>
    </div>

    <footer class="pt-5 pb-4 mt-5 footer">
        <div class="container">
            <div class="row">
                <div class="col-md-5">
                    <a class="navbar-brand fw-bold fs-3" href="/"><i class="bi bi-code-square me-2 text-primary"></i>CodeArena</a>
                    <p class="text-secondary small col-lg-8 mt-3">Compete in coding contests and improve your skills.</p>
                </div>
                <div class="col-md-7">
                    <div class="row">
                        <div class="col-4"><h6>Platform</h6><ul class="list-unstyled small"><li><a href="/Problem">Problems</a></li><li><a href="/Contest">Contests</a></li></ul></div>
                        <div class="col-4"><h6>Support</h6><ul class="list-unstyled small"><li><a href="#">FAQ</a></li></ul></div>
                        <div class="col-4"><h6>Team</h6><ul class="list-unstyled small"><li><a href="#">About</a></li></ul></div>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script>
        // Countdown
        function updateCountdown() {
            const timer = document.querySelector('.countdown-large');
            if (timer) {
                const endTime = new Date(timer.dataset.end).getTime();
                const now = new Date().getTime();
                const distance = endTime - now;

                if (distance < 0) {
                    timer.innerHTML = "Ended";
                } else {
                    const hours = Math.floor(distance / (1000 * 60 * 60));
                    const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                    const seconds = Math.floor((distance % (1000 * 60)) / 1000);
                    
                    timer.innerHTML = `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
                }
            }
        }

        setInterval(updateCountdown, 1000);

        // Copy contest link
        window.copyContestLink = function() {
            const link = document.getElementById('contestLink').innerText;
            navigator.clipboard.writeText(link).then(() => {
                alert('Contest link copied to clipboard!');
            });
        };

        // Theme toggle
        const toggleBtn = document.getElementById('themeToggle');
        const themeText = document.getElementById('themeText');
        const body = document.body;

        if (localStorage.getItem('theme') === 'dark') {
            body.classList.add('dark');
            themeText.innerText = 'Dark';
            toggleBtn.innerHTML = '<i class="bi bi-moon-stars-fill me-1"></i> Dark';
        }

        toggleBtn.addEventListener('click', () => {
            body.classList.toggle('dark');
            if (body.classList.contains('dark')) {
                localStorage.setItem('theme', 'dark');
                themeText.innerText = 'Dark';
                toggleBtn.innerHTML = '<i class="bi bi-moon-stars-fill me-1"></i> Dark';
            } else {
                localStorage.setItem('theme', 'light');
                themeText.innerText = 'Light';
                toggleBtn.innerHTML = '<i class="bi bi-sun-fill me-1"></i> Light';
            }
        });
    </script>
</body>
</html>