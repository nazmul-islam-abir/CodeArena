@model MyMvcApp.Models.Contest
@{
    ViewData["Title"] = "Edit Contest";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card p-4">
                <h3 class="fw-bold mb-4"><i class="bi bi-pencil-square me-2 text-primary"></i>Edit Contest</h3>
                
                <form method="post" action="/Contest/Edit/@Model.Id">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" name="Id" value="@Model.Id" />
                    
                    <div class="mb-3">
                        <label class="form-label">Contest Title</label>
                        <input type="text" class="form-control" name="Title" value="@Model.Title" required>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" name="Description" rows="4" required>@Model.Description</textarea>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Organizer</label>
                        <input type="text" class="form-control" name="Organizer" value="@Model.Organizer" required>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Start Date & Time</label>
                            <input type="datetime-local" class="form-control" name="StartTime" value="@Model.StartTime.ToString("yyyy-MM-ddTHH:mm")" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Duration (hours)</label>
                            <select class="form-select" name="Duration">
                                <option value="1 hour" selected="@(Model.Duration == "1 hour")">1 hour</option>
                                <option value="2 hours" selected="@(Model.Duration == "2 hours")">2 hours</option>
                                <option value="3 hours" selected="@(Model.Duration == "3 hours")">3 hours</option>
                                <option value="4 hours" selected="@(Model.Duration == "4 hours")">4 hours</option>
                                <option value="24 hours" selected="@(Model.Duration == "24 hours")">24 hours</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Difficulty</label>
                            <select class="form-select" name="Difficulty">
                                <option selected="@(Model.Difficulty == "Easy")">Easy</option>
                                <option selected="@(Model.Difficulty == "Medium")">Medium</option>
                                <option selected="@(Model.Difficulty == "Hard")">Hard</option>
                                <option selected="@(Model.Difficulty == "Mixed")">Mixed</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Problem IDs (comma separated)</label>
                        <input type="text" class="form-control" name="problemIds" value="@ViewBag.ProblemIds" placeholder="e.g. 1, 2, 5" required>
                        @Html.ValidationMessage("problemIds", new { @class = "text-danger" })
                        <div class="form-text">Update the IDs of the problems you want to include in this contest.</div>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary py-2 flex-grow-1">
                            <i class="bi bi-save me-2"></i>Save Changes
                        </button>
                        <a href="/Contest/Details/@Model.Id" class="btn btn-outline-secondary py-2">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
