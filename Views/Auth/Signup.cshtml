@model MyMvcApp.Models.SignupViewModel
@{
    ViewData["Title"] = "Sign Up";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <i class="bi bi-code-square fs-1 text-primary"></i>
                        <h2 class="fw-bold mt-2">Create Account</h2>
                        <p class="text-secondary">Join CodeArena to start coding</p>
                    </div>

                    @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                    <form method="post" action="/Auth/Signup">
                        @Html.AntiForgeryToken()
                        <div class="row">
                            <div class="col-md-6 mb-3"><label class="form-label">First Name</label>@Html.TextBoxFor(m => m.FirstName, new { @class = "form-control", placeholder = "John" })@Html.ValidationMessageFor(m => m.FirstName, "", new { @class = "text-danger" })</div>
                            <div class="col-md-6 mb-3"><label class="form-label">Last Name</label>@Html.TextBoxFor(m => m.LastName, new { @class = "form-control", placeholder = "Doe" })@Html.ValidationMessageFor(m => m.LastName, "", new { @class = "text-danger" })</div>
                        </div>
                        <div class="mb-3"><label class="form-label">Username</label><div class="input-group"><span class="input-group-text"><i class="bi bi-person"></i></span>@Html.TextBoxFor(m => m.Username, new { @class = "form-control", placeholder = "johndoe" })</div>@Html.ValidationMessageFor(m => m.Username, "", new { @class = "text-danger" })</div>
                        <div class="mb-3"><label class="form-label">Email</label><div class="input-group"><span class="input-group-text"><i class="bi bi-envelope"></i></span>@Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "john@example.com" })</div>@Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })</div>
                        <div class="mb-3"><label class="form-label">Student ID (Optional)</label>@Html.TextBoxFor(m => m.StudentId, new { @class = "form-control", placeholder = "0222310005101078" })@Html.ValidationMessageFor(m => m.StudentId, "", new { @class = "text-danger" })</div>
                        <div class="mb-3"><label class="form-label">Password</label><div class="input-group"><span class="input-group-text"><i class="bi bi-lock"></i></span>@Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Create a password" })</div>@Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })</div>
                        <div class="mb-4"><label class="form-label">Confirm Password</label><div class="input-group"><span class="input-group-text"><i class="bi bi-lock-fill"></i></span>@Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control", placeholder = "Confirm your password" })</div>@Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger" })</div>
                        <div class="mb-4 form-check">@Html.CheckBoxFor(m => m.AgreeToTerms, new { @class = "form-check-input" })<label class="form-check-label" for="AgreeToTerms">I agree to the <a href="#" style="color:var(--primary);">Terms of Service</a></label>@Html.ValidationMessageFor(m => m.AgreeToTerms, "", new { @class = "text-danger" })</div>
                        <button type="submit" class="btn btn-primary w-100 mb-3 py-2">Create Account</button>
                    </form>

                    <p class="text-center mt-4 text-secondary">Already have an account? <a href="/Auth/Login" class="text-decoration-none" style="color:var(--primary);">Log in</a></p>
                </div>
            </div>
        </div>
    </div>
</div>