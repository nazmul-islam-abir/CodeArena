@model MyMvcApp.Models.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="profile-cover mb-4">
        <div class="cover-image"></div>
        <div class="profile-header-content">
            <div class="avatar-wrapper">
                <div class="avatar-circle">@Model.FirstName.Substring(0, 1)@Model.LastName.Substring(0, 1)</div>
                <span class="role-badge @Model.Role.ToLower()">@Model.Role</span>
            </div>
            <div class="profile-title">
                <h1 class="display-6 fw-bold mb-1">@Model.FullName</h1>
                <p class="text-secondary mb-2">@@@Model.Username</p>
                <div class="d-flex gap-3 flex-wrap">
                    <span class="badge-feature"><i class="bi bi-calendar3 me-1"></i>Joined @Model.MemberSince</span>
                    <span class="badge-feature"><i class="bi bi-clock-history me-1"></i>Last active @Model.LastActive</span>
                    <a href="/Submissions?userId=@Model.Id" class="btn btn-outline-theme">My Submissions</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="stats-grid mb-4">
                <div class="stat-card"><div class="stat-icon solved"><i class="bi bi-check2-circle"></i></div><div class="stat-content"><h3 class="fw-bold mb-0">@Model.ProblemsSolved</h3><small>Problems Solved</small></div></div>
                <div class="stat-card"><div class="stat-icon contests"><i class="bi bi-trophy"></i></div><div class="stat-content"><h3 class="fw-bold mb-0">@Model.ContestsParticipated</h3><small>Contests</small></div></div>
                <div class="stat-card"><div class="stat-icon points"><i class="bi bi-star-fill"></i></div><div class="stat-content"><h3 class="fw-bold mb-0">@Model.TotalPoints</h3><small>Total Points</small></div></div>
            </div>

            <div class="card info-card mb-4">
                <div class="card-header"><i class="bi bi-info-circle me-2 text-primary"></i><h5 class="fw-bold mb-0">Contact Information</h5></div><div class="card-body">
                <div class="info-item"><div class="info-icon"><i class="bi bi-envelope-fill"></i></div><div class="info-content"><small class="text-secondary">Email Address</small><p class="mb-0 fw-medium">@Model.Email</p></div></div>
                @if (!string.IsNullOrEmpty(Model.StudentId))
                {
                    <div class="info-item"><div class="info-icon"><i class="bi bi-person-badge-fill"></i></div><div class="info-content"><small class="text-secondary">Student ID</small><p class="mb-0 fw-medium">@Model.StudentId</p></div></div>
                }
                <div class="info-item"><div class="info-icon"><i class="bi bi-calendar-check-fill"></i></div><div class="info-content"><small class="text-secondary">Member Since</small><p class="mb-0 fw-medium">@Model.MemberSince</p></div></div>
            </div>
        </div>

        <div class="card">
            <div class="card-header"><i class="bi bi-award me-2 text-warning"></i><h5 class="fw-bold mb-0">Achievements</h5></div><div class="card-body">
            <div class="achievement-grid">
                <div class="achievement-item"><div class="achievement-icon beginner"><i class="bi bi-emoji-smile"></i></div><span>Beginner</span></div>
                <div class="achievement-item"><div class="achievement-icon @(Model.ProblemsSolved >= 10 ? "unlocked" : "locked")"><i class="bi bi-check-circle"></i></div><span>10 Problems</span></div>
                <div class="achievement-item"><div class="achievement-icon @(Model.ContestsParticipated >= 5 ? "unlocked" : "locked")"><i class="bi bi-trophy"></i></div><span>5 Contests</span></div>
                <div class="achievement-item"><div class="achievement-icon @(Model.ProblemsSolved >= 30 ? "unlocked" : "locked")"><i class="bi bi-fire"></i></div><span>30 Problems</span></div>
            </div>
        </div>
    </div>
</div>

<div class="col-lg-8">
    <div class="card mb-4"><div class="card-header"><i class="bi bi-gear me-2 text-primary"></i><h5 class="fw-bold mb-0">Account Settings</h5></div><div class="card-body"><form method="post" action="/Auth/UpdateProfile">@Html.AntiForgeryToken()<div class="row g-3"><div class="col-md-6"><label class="form-label">First Name</label><input type="text" class="form-control profile-input" value="@Model.FirstName" readonly disabled></div><div class="col-md-6"><label class="form-label">Last Name</label><input type="text" class="form-control profile-input" value="@Model.LastName" readonly disabled></div></div><div class="mt-3"><label class="form-label">Username</label><div class="input-group"><span class="input-group-text">@@</span><input type="text" class="form-control profile-input" value="@Model.Username" readonly disabled></div></div><div class="alert alert-info mt-4 d-flex align-items-center"><i class="bi bi-info-circle-fill me-3 fs-4"></i><div><strong>Profile editing will be available in a future update.</strong></div></div></form></div></div>

    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-check-circle-fill me-2 text-success"></i><h5 class="fw-bold mb-0">Solved Problems (@Model.ProblemsSolved)</h5></div><div class="card-body">
        @if (ViewBag.SolvedProblems != null && ((IEnumerable<dynamic>)ViewBag.SolvedProblems).Count() > 0)
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead><tr><th>#</th><th>Problem</th><th>Difficulty</th><th>Points</th></thead>
                    <tbody>
                        @{
                            int idx = 1;
                        }
                        @foreach (var problem in ViewBag.SolvedProblems)
                        {
                            <tr>
                                <td>@idx++</td>
                                <td><a href="/Problem/Details/@problem.Id" class="text-decoration-none fw-medium">@problem.Title</a></td>
                                <td>@if (problem.Difficulty == 1) {
                                    <span class="badge bg-success">Easy</span>
                                } else if (problem.Difficulty == 2)
                                {

                                    <span class="badge bg-warning">Medium</span>
                                }
                                else
                                {

                                    <span class="badge bg-danger">Hard</span>
                                }
                            </td>
                            <td><span class="badge bg-info">@problem.Points pts</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
                else
    {

        <div class="text-center py-4"><i class="bi bi-inbox fs-1 text-secondary"></i><p class="text-secondary mt-2">No problems solved yet.</p><a href="/Problem" class="btn btn-primary mt-2">Browse Problems</a></div>
    }
</div>
</div>
</div>
</div>
</div>