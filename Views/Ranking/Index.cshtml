@model IEnumerable<MyMvcApp.Models.User>
@{
    ViewData["Title"] = "Global Ranking";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var topUsers = Model.ToList();
    var first = topUsers.Count > 0 ? topUsers[0] : null;
    var second = topUsers.Count > 1 ? topUsers[1] : null;
    var third = topUsers.Count > 2 ? topUsers[2] : null;

    string GetBadgeClass(int points)
    {
        if (points >= 1800) return "badge-gm";
        if (points >= 1500) return "badge-master";
        if (points >= 1300) return "badge-expert";
        if (points >= 1100) return "badge-specialist";
        if (points >= 800) return "badge-pupil";
        return "badge-newbie";
    }

    string GetRatingTitle(int points)
    {
        if (points >= 1800) return "Grandmaster";
        if (points >= 1500) return "Master";
        if (points >= 1300) return "Expert";
        if (points >= 1100) return "Specialist";
        if (points >= 800) return "Pupil";
        return "Newbie";
    }

    string GetTimeAgo(DateTime? date)
    {
        if (!date.HasValue) return "Never";
        var span = DateTime.UtcNow - date.Value;
        if (span.TotalDays > 1) return $"{(int)span.TotalDays} days ago";
        if (span.TotalHours > 1) return $"{(int)span.TotalHours} hours ago";
        if (span.TotalMinutes > 1) return $"{(int)span.TotalMinutes} mins ago";
        return "Just now";
    }
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div><h1 class="fw-bold display-5 mb-2"><i class="bi bi-trophy-fill text-warning me-3"></i>Global Ranking</h1><p class="text-secondary fs-5">Top coders ranked by points and problems solved</p></div>
    </div>

    <div class="row g-4 mb-5 justify-content-center">
        @if (second != null)
        {
            <div class="col-md-4 order-2 order-md-1">
                <div class="card p-4 text-center h-100 shadow-sm">
                    <div class="position-relative mb-3"><span class="position-absolute top-0 start-50 translate-middle badge rounded-pill bg-secondary px-3 py-2" style="font-size:0.9rem;">2nd</span><div class="rounded-circle bg-light d-flex align-items-center justify-content-center mx-auto shadow-inner" style="width:100px;height:100px;"><i class="bi bi-person-circle" style="font-size:4rem;color:#c0c0c0;"></i></div></div>
                    <h4 class="fw-bold mb-1">@second.FullName</h4><p class="text-secondary small mb-3">@@@second.Username</p>
                    <div class="d-flex justify-content-center gap-3 mb-3 small fw-medium"><span class="text-primary"><i class="bi bi-lightning-fill me-1"></i>@second.TotalPoints pts</span><span class="text-success"><i class="bi bi-check-circle-fill me-1"></i>@second.ProblemsSolved solved</span></div>
                    <span class="badge-rating @GetBadgeClass(second.TotalPoints) mx-auto">@GetRatingTitle(second.TotalPoints)</span>
                </div>
            </div>
        }
        
        @if (first != null)
        {
            <div class="col-md-4 order-1 order-md-2">
                <div class="card p-5 text-center h-100 border-warning border-3 shadow">
                    <div class="position-relative mb-4"><span class="position-absolute top-0 start-50 translate-middle badge rounded-pill bg-warning text-dark px-4 py-2" style="font-size:1rem;border:4px solid var(--bg-card);">1st</span><div class="rounded-circle bg-warning bg-opacity-10 d-flex align-items-center justify-content-center mx-auto shadow-inner" style="width:120px;height:120px;border:4px solid #ffd700;"><i class="bi bi-person-circle" style="font-size:5rem;color:#ffd700;"></i></div></div>
                    <h3 class="fw-bold mb-1">@first.FullName</h3><p class="text-secondary mb-3">@@@first.Username</p>
                    <div class="d-flex justify-content-center gap-4 mb-4 fw-bold"><span class="text-primary"><i class="bi bi-lightning-fill me-1"></i>@first.TotalPoints pts</span><span class="text-success"><i class="bi bi-check-circle-fill me-1"></i>@first.ProblemsSolved solved</span></div>
                    <span class="badge-rating @GetBadgeClass(first.TotalPoints) mx-auto px-4 py-2 fs-5">@GetRatingTitle(first.TotalPoints)</span>
                </div>
            </div>
        }
        
        @if (third != null)
        {
            <div class="col-md-4 order-3 order-md-3">
                <div class="card p-4 text-center h-100 shadow-sm">
                    <div class="position-relative mb-3"><span class="position-absolute top-0 start-50 translate-middle badge rounded-pill px-3 py-2" style="font-size:0.9rem;background:#cd7f32;">3rd</span><div class="rounded-circle bg-light d-flex align-items-center justify-content-center mx-auto shadow-inner" style="width:100px;height:100px;"><i class="bi bi-person-circle" style="font-size:4rem;color:#cd7f32;"></i></div></div>
                    <h4 class="fw-bold mb-1">@third.FullName</h4><p class="text-secondary small mb-3">@@@third.Username</p>
                    <div class="d-flex justify-content-center gap-3 mb-3 small fw-medium"><span class="text-primary"><i class="bi bi-lightning-fill me-1"></i>@third.TotalPoints pts</span><span class="text-success"><i class="bi bi-check-circle-fill me-1"></i>@third.ProblemsSolved solved</span></div>
                    <span class="badge-rating @GetBadgeClass(third.TotalPoints) mx-auto">@GetRatingTitle(third.TotalPoints)</span>
                </div>
            </div>
        }
    </div>

    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="card-header bg-white border-bottom p-4"><h5 class="fw-bold mb-0">Leaderboard</h5></div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light"><tr><th class="ps-4" style="width:100px;">Rank</th><th>Coder</th><th class="text-center">Solved</th><th class="text-center">Points</th><th class="text-center">Rating</th><th class="text-center pe-4">Last Active</th></tr></thead>
                <tbody>
                    @for (int i = 0; i < topUsers.Count; i++)
                    {
                        var user = topUsers[i];
                        int rank = i + 1;
                        string rowClass = rank switch { 1 => "rank-1", 2 => "rank-2", 3 => "rank-3", _ => "" };
                        <tr class="@rowClass">
                            <td class="ps-4">@if (rank <= 3) {
                                <span class="badge rounded-pill @(rank == 1 ? "bg-warning text-dark" : rank == 2 ? "bg-secondary" : "bg-bronze") px-3">#@rank @(rank == 1 ? "🥇" : rank == 2 ? "🥈" : "🥉")</span>
                            } else
                            {

                                <span class="fw-bold text-secondary ms-2">#@rank</span>
                            }
                        </td>
                        <td><div class="d-flex align-items-center"><div class="rounded-circle bg-light d-flex align-items-center justify-content-center me-3" style="width:40px;height:40px;"><i class="bi bi-person-fill text-secondary"></i></div><div><div class="fw-bold">@user.FullName</div><div class="text-secondary small">@@@user.Username</div></div></div></td>
                        <td class="text-center fw-medium">@user.ProblemsSolved</td>
                        <td class="text-center"><span class="badge bg-primary bg-opacity-10 text-primary px-3 fw-bold">@user.TotalPoints</span></td>
                        <td class="text-center"><span class="badge-rating @GetBadgeClass(user.TotalPoints) small">@GetRatingTitle(user.TotalPoints)</span></td>
                        <td class="text-center text-secondary small pe-4">@GetTimeAgo(user.LastLoginAt)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
</div>