@{
    ViewData["Title"] = "Ranking Page";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CodeArena · Global Ranking</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-body: #f8fafc;
            --bg-card: #ffffff;
            --text-primary: #0f172a;
            --text-secondary: #334155;
            --navbar-bg: #ffffffcc;
            --footer-bg: #eef2f6;
            --border-light: #e2e8f0;
            --primary: #0284c7;
            --primary-light: #e0f2fe;
            --table-header-bg: #f1f5f9;
            --table-row-hover: #f8fafc;
            --rank-1: #ffd700;
            --rank-2: #c0c0c0;
            --rank-3: #cd7f32;
        }
        body.dark {
            --bg-body: #0b1120;
            --bg-card: #1e293b;
            --text-primary: #f1f5f9;
            --text-secondary: #cbd5e1;
            --navbar-bg: #1e293be6;
            --footer-bg: #0f172a;
            --border-light: #334155;
            --primary: #38bdf8;
            --primary-light: #1e3a5f;
            --table-header-bg: #2d3a4f;
            --table-row-hover: #263445;
            --rank-1: #fbbf24;
            --rank-2: #94a3b8;
            --rank-3: #b45309;
        }
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-primary);
            transition: all 0.2s ease;
        }
        .navbar {
            background-color: var(--navbar-bg) !important;
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border-light);
        }
        .navbar-brand, .nav-link {
            color: var(--text-primary) !important;
        }
        .theme-toggle {
            background: transparent;
            border: 1px solid var(--border-light);
            color: var(--text-primary);
            padding: 0.4rem 1rem;
            border-radius: 60px;
            cursor: pointer;
        }
        .btn-outline-theme {
            border-color: var(--border-light);
            color: var(--text-primary);
        }
        .btn-outline-theme:hover {
            background-color: var(--primary);
            border-color: var(--primary);
            color: white;
        }
        .card {
            background-color: var(--bg-card);
            border: 1px solid var(--border-light);
            border-radius: 24px;
        }
        .table {
            color: var(--text-primary);
        }
        .table thead th {
            background-color: var(--table-header-bg);
            color: var(--text-primary);
            border-bottom-color: var(--border-light);
        }
        .table tbody tr {
            background-color: var(--bg-card);
        }
        .table tbody tr:hover {
            background-color: var(--table-row-hover);
        }
        .table td, .table th {
            border-color: var(--border-light);
            color: var(--text-primary);
        }
        .rank-1 { background-color: rgba(255, 215, 0, 0.1); }
        .rank-2 { background-color: rgba(192, 192, 192, 0.1); }
        .rank-3 { background-color: rgba(205, 127, 50, 0.1); }
        .badge-rating {
            padding: 0.3rem 0.8rem;
            border-radius: 20px;
            font-weight: 600;
        }
        .badge-gm { background: linear-gradient(135deg, #ffd700, #ff8c00); color: #000; }
        .badge-master { background: linear-gradient(135deg, #c0c0c0, #808080); color: #fff; }
        .badge-expert { background: #3b82f6; color: #fff; }
        .badge-specialist { background: #10b981; color: #fff; }
        .badge-pupil { background: #8b5cf6; color: #fff; }
        .badge-newbie { background: #6b7280; color: #fff; }
        footer {
            background-color: var(--footer-bg);
            border-top: 1px solid var(--border-light);
        }
    </style>
</head>
<body>

    <div class="container py-5">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold"><i class="bi bi-trophy-fill text-warning me-2"></i>Global Ranking</h2>
                <p class="text-secondary">Top coders ranked by points and rating</p>
            </div>
            <div class="d-flex gap-3">
                <select class="form-select" style="width: auto; background-color: var(--bg-card); color: var(--text-primary); border-color: var(--border-light);">
                    <option>All Time</option>
                    <option>This Month</option>
                    <option>This Week</option>
                </select>
                <select class="form-select" style="width: auto; background-color: var(--bg-card); color: var(--text-primary); border-color: var(--border-light);">
                    <option>All Countries</option>
                    <option>Bangladesh</option>
                    <option>India</option>
                    <option>USA</option>
                </select>
            </div>
        </div>

        <!-- Top 3 Coders -->
        <div class="row g-4 mb-5">
            <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                <div class="card p-4 text-center h-100">
                    <div class="position-relative">
                        <span class="position-absolute top-0 start-50 translate-middle badge rounded-pill bg-secondary" style="font-size: 1rem;">2nd</span>
                        <i class="bi bi-person-circle" style="font-size: 4rem; color: #c0c0c0;"></i>
                    </div>
                    <h4 class="mt-3">Junayed Jasim</h4>
                    <p class="text-secondary mb-2">@@junayed</p>
                    <div class="d-flex justify-content-center gap-3 mb-3">
                        <span><i class="bi bi-check-circle text-success"></i> 1620 pts</span>
                        <span><i class="bi bi-trophy text-warning"></i> 21 solved</span>
                    </div>
                    <span class="badge-rating badge-master mx-auto">Master</span>
                </div>
            </div>
            <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                <div class="card p-4 text-center h-100 border-warning border-2">
                    <div class="position-relative">
                        <span class="position-absolute top-0 start-50 translate-middle badge rounded-pill bg-warning text-dark" style="font-size: 1rem;">1st</span>
                        <i class="bi bi-person-circle" style="font-size: 4rem; color: #ffd700;"></i>
                    </div>
                    <h4 class="mt-3">Minhaz Uddin</h4>
                    <p class="text-secondary mb-2">@@minhaz</p>
                    <div class="d-flex justify-content-center gap-3 mb-3">
                        <span><i class="bi bi-check-circle text-success"></i> 1840 pts</span>
                        <span><i class="bi bi-trophy text-warning"></i> 24 solved</span>
                    </div>
                    <span class="badge-rating badge-gm mx-auto">Grandmaster</span>
                </div>
            </div>
            <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
                <div class="card p-4 text-center h-100">
                    <div class="position-relative">
                        <span class="position-absolute top-0 start-50 translate-middle badge rounded-pill bg-bronze" style="font-size: 1rem; background: #cd7f32;">3rd</span>
                        <i class="bi bi-person-circle" style="font-size: 4rem; color: #cd7f32;"></i>
                    </div>
                    <h4 class="mt-3">Nazmul Islam</h4>
                    <p class="text-secondary mb-2">@@nazmul</p>
                    <div class="d-flex justify-content-center gap-3 mb-3">
                        <span><i class="bi bi-check-circle text-success"></i> 1480 pts</span>
                        <span><i class="bi bi-trophy text-warning"></i> 19 solved</span>
                    </div>
                    <span class="badge-rating badge-expert mx-auto">Expert</span>
                </div>
            </div>
        </div>

        <!-- Ranking Table -->
        <div class="card p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold">Top 50 Coders</h5>
                <div class="input-group" style="width: 250px;">
                    <span class="input-group-text bg-transparent border-end-0" style="border-color: var(--border-light);"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control border-start-0" placeholder="Search coder..." style="background-color: var(--bg-card); color: var(--text-primary); border-color: var(--border-light);">
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Rank</th>
                            <th>Coder</th>
                            <th>Country</th>
                            <th>Solved</th>
                            <th>Points</th>
                            <th>Rating</th>
                            <th>Last Active</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="rank-1">
                            <td><span class="fw-bold">1</span> 🥇</td>
                            <td><i class="bi bi-person-circle me-2"></i> Minhaz Uddin</td>
                            <td>🇧🇩 Bangladesh</td>
                            <td>24</td>
                            <td><strong>1840</strong></td>
                            <td><span class="badge-rating badge-gm">Grandmaster</span></td>
                            <td>2 min ago</td>
                        </tr>
                        <tr class="rank-2">
                            <td><span class="fw-bold">2</span> 🥈</td>
                            <td><i class="bi bi-person-circle me-2"></i> Junayed Jasim</td>
                            <td>🇧🇩 Bangladesh</td>
                            <td>21</td>
                            <td>1620</td>
                            <td><span class="badge-rating badge-master">Master</span></td>
                            <td>5 min ago</td>
                        </tr>
                        <tr class="rank-3">
                            <td><span class="fw-bold">3</span> 🥉</td>
                            <td><i class="bi bi-person-circle me-2"></i> Nazmul Islam</td>
                            <td>🇧🇩 Bangladesh</td>
                            <td>19</td>
                            <td>1480</td>
                            <td><span class="badge-rating badge-expert">Expert</span></td>
                            <td>10 min ago</td>
                        </tr>
                        <tr>
                            <td>4</td>
                            <td><i class="bi bi-person-circle me-2"></i> Md. Abdullah</td>
                            <td>🇧🇩 Bangladesh</td>
                            <td>18</td>
                            <td>1405</td>
                            <td><span class="badge-rating badge-specialist">Specialist</span></td>
                            <td>15 min ago</td>
                        </tr>
                        <tr>
                            <td>5</td>
                            <td><i class="bi bi-person-circle me-2"></i> Sarah Khan</td>
                            <td>🇧🇩 Bangladesh</td>
                            <td>16</td>
                            <td>1320</td>
                            <td><span class="badge-rating badge-specialist">Specialist</span></td>
                            <td>1 hour ago</td>
                        </tr>
                        <tr>
                            <td>6</td>
                            <td><i class="bi bi-person-circle me-2"></i> Rajib Ahmed</td>
                            <td>🇮🇳 India</td>
                            <td>15</td>
                            <td>1280</td>
                            <td><span class="badge-rating badge-pupil">Pupil</span></td>
                            <td>2 hours ago</td>
                        </tr>
                        <tr>
                            <td>7</td>
                            <td><i class="bi bi-person-circle me-2"></i> Priya Das</td>
                            <td>🇮🇳 India</td>
                            <td>14</td>
                            <td>1210</td>
                            <td><span class="badge-rating badge-pupil">Pupil</span></td>
                            <td>3 hours ago</td>
                        </tr>
                        <tr>
                            <td>8</td>
                            <td><i class="bi bi-person-circle me-2"></i> Tanvir Hasan</td>
                            <td>🇧🇩 Bangladesh</td>
                            <td>13</td>
                            <td>1150</td>
                            <td><span class="badge-rating badge-pupil">Pupil</span></td>
                            <td>5 hours ago</td>
                        </tr>
                        <tr>
                            <td>9</td>
                            <td><i class="bi bi-person-circle me-2"></i> Rifat Chowdhury</td>
                            <td>🇧🇩 Bangladesh</td>
                            <td>12</td>
                            <td>1080</td>
                            <td><span class="badge-rating badge-newbie">Newbie</span></td>
                            <td>6 hours ago</td>
                        </tr>
                        <tr>
                            <td>10</td>
                            <td><i class="bi bi-person-circle me-2"></i> John Smith</td>
                            <td>🇺🇸 USA</td>
                            <td>11</td>
                            <td>1020</td>
                            <td><span class="badge-rating badge-newbie">Newbie</span></td>
                            <td>8 hours ago</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <nav class="mt-3">
                <ul class="pagination justify-content-center">
                    <li class="page-item disabled"><a class="page-link" href="#" style="background-color: var(--bg-card); color: var(--text-primary); border-color: var(--border-light);">Previous</a></li>
                    <li class="page-item active"><a class="page-link" href="#" style="background-color: var(--primary); border-color: var(--primary);">1</a></li>
                    <li class="page-item"><a class="page-link" href="#" style="background-color: var(--bg-card); color: var(--text-primary); border-color: var(--border-light);">2</a></li>
                    <li class="page-item"><a class="page-link" href="#" style="background-color: var(--bg-card); color: var(--text-primary); border-color: var(--border-light);">3</a></li>
                    <li class="page-item"><a class="page-link" href="#" style="background-color: var(--bg-card); color: var(--text-primary); border-color: var(--border-light);">Next</a></li>
                </ul>
            </nav>
        </div>
    </div>


    <script>
        const toggleBtn = document.getElementById('themeToggle');
        const themeText = document.getElementById('themeText');
        const body = document.body;

        if (localStorage.getItem('theme') === 'dark') {
            body.classList.add('dark');
            themeText.innerText = 'Dark';
            toggleBtn.innerHTML = '<i class="bi bi-moon-stars-fill me-1"></i> Dark';
        }

        toggleBtn.addEventListener('click', () => {
            body.classList.toggle('dark');
            if (body.classList.contains('dark')) {
                localStorage.setItem('theme', 'dark');
                themeText.innerText = 'Dark';
                toggleBtn.innerHTML = '<i class="bi bi-moon-stars-fill me-1"></i> Dark';
            } else {
                localStorage.setItem('theme', 'light');
                themeText.innerText = 'Light';
                toggleBtn.innerHTML = '<i class="bi bi-sun-fill me-1"></i> Light';
            }
        });
    </script>
</body>
</html>