@{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<section id="home" class="pt-5 pb-4">
    <div class="container py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-6" data-aos="fade-right">
                @if (Context.Session.GetString("UserId") != null)
                {
                    <span class="badge-feature mb-3 d-inline-block">
                        <i class="bi bi-person-circle me-1"></i> Welcome back, @Context.Session.GetString("UserFullName")!
                    </span>
                }
                else
                {
                    <span class="badge-feature mb-3 d-inline-block"><i class="bi bi-cpu me-1"></i> v2.0 · Launching soon</span>
                }
                <h1 class="display-4 fw-bold mb-4">Where code meets <span class="text-gradient">challenge</span></h1>
                <p class="lead mb-4 text-secondary">Online programming judge with real contest system, automated evaluation, hidden test cases & live leaderboard.</p>
                <div class="d-flex flex-wrap gap-3 mb-4">
                    <div><i class="bi bi-check-circle-fill text-primary me-1"></i> C++ supported</div>
                    <div><i class="bi bi-check-circle-fill text-primary me-1"></i> TLE / MLE checks</div>
                    <div><i class="bi bi-check-circle-fill text-primary me-1"></i> Contest timer</div>
                </div>
                <div class="d-flex gap-3">
                    <a href="#features" class="btn btn-primary btn-lg px-5 py-3 rounded-pill">Explore <i class="bi bi-arrow-right-short"></i></a>
                    <a href="/Compiler" class="btn btn-outline-theme btn-lg px-5 py-3 rounded-pill">Try Compiler</a>
                </div>
            </div>
            <div class="col-lg-6" data-aos="fade-left">
                <div class="card p-4 border-0">
                    <img src="https://placehold.co/600x400/0f172a/ffffff?text=Live+Editor+Preview" class="rounded-4 img-fluid" alt="editor preview">
                    <div class="d-flex justify-content-between mt-3 text-muted small">
                        <span><i class="bi bi-filetype-cpp me-1"></i> main.cpp</span>
                        <span><i class="bi bi-play-circle-fill text-success"></i> Run</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-4">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4" data-aos="zoom-in" data-aos-delay="100">
                <div class="card p-4 h-100 border-0">
                    <i class="bi bi-people-fill fs-1 text-primary mb-3"></i>
                    <h4>200+ active coders</h4>
                    <p class="text-secondary">University-level practice platform with weekly internal contests.</p>
                </div>
            </div>
            <div class="col-md-4" data-aos="zoom-in" data-aos-delay="200">
                <div class="card p-4 h-100 border-0">
                    <i class="bi bi-trophy-fill fs-1 text-warning mb-3"></i>
                    <h4>Real-time ELO</h4>
                    <p class="text-secondary">Dynamic ranking based on problem difficulty & contest performance.</p>
                </div>
            </div>
            <div class="col-md-4" data-aos="zoom-in" data-aos-delay="300">
                <div class="card p-4 h-100 border-0">
                    <i class="bi bi-shield-lock-fill fs-1 text-success mb-3"></i>
                    <h4>Hidden test cases</h4>
                    <p class="text-secondary">Anti-plagiarism & secure evaluation against brute force.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="features" class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge-feature">platform deep-dive</span>
            <h2 class="display-5 fw-bold mt-3">Everything inside the arena</h2>
            <p class="col-lg-7 mx-auto text-secondary">From admin monitoring to contest timers – built for students, teachers, and competitive programmers.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-4" data-aos="flip-left">
                <div class="card p-4 h-100">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <i class="bi bi-person-badge fs-1" style="color: var(--primary);"></i>
                        <h5 class="fw-bold mb-0">Role‑based access</h5>
                    </div>
                    <p class="text-secondary mb-0">Admin, user, and contestant roles. Admins manage problems, test cases, and approve contests.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4" data-aos="flip-left" data-aos-delay="100">
                <div class="card p-4 h-100">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <i class="bi bi-bar-chart-steps fs-1 text-warning"></i>
                        <h5 class="fw-bold mb-0">Live leaderboard</h5>
                    </div>
                    <p class="text-secondary mb-0">Points based on difficulty, tracks solved count, updates instantly during contests.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4" data-aos="flip-left" data-aos-delay="200">
                <div class="card p-4 h-100">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <i class="bi bi-clock-history fs-1 text-danger"></i>
                        <h5 class="fw-bold mb-0">TLE / MLE check</h5>
                    </div>
                    <p class="text-secondary mb-0">Strict time & memory limits enforced using free compiler API.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge-feature">practice makes perfect</span>
            <h2 class="display-5 fw-bold mt-3">Featured Problems</h2>
            <p class="col-lg-7 mx-auto text-secondary">Start with these popular problems and improve your coding skills.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4" data-aos="fade-up">
                <div class="card p-4 h-100">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="badge bg-success">Easy</span>
                        <span class="text-warning">10 pts</span>
                    </div>
                    <h5>Sum of Two Numbers</h5>
                    <p class="text-secondary small">Calculate the sum of two integers. Basic input/output practice.</p>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <span class="text-secondary"><i class="bi bi-check-circle-fill text-success me-1"></i> 245 solved</span>
                        <a href="/Problem/Solve/1" class="btn btn-sm btn-outline-primary">Solve →</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                <div class="card p-4 h-100">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="badge bg-warning">Medium</span>
                        <span class="text-warning">30 pts</span>
                    </div>
                    <h5>Factorial</h5>
                    <p class="text-secondary small">Calculate factorial of a number. Practice loops and recursion.</p>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <span class="text-secondary"><i class="bi bi-check-circle-fill text-success me-1"></i> 156 solved</span>
                        <a href="/Problem/Solve/3" class="btn btn-sm btn-outline-primary">Solve →</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                <div class="card p-4 h-100">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="badge bg-danger">Hard</span>
                        <span class="text-warning">60 pts</span>
                    </div>
                    <h5>Binary Search</h5>
                    <p class="text-secondary small">Implement binary search in a sorted array.</p>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <span class="text-secondary"><i class="bi bi-check-circle-fill text-success me-1"></i> 76 solved</span>
                        <a href="/Problem/Solve/9" class="btn btn-sm btn-outline-primary">Solve →</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="text-center mt-5">
            <a href="/Problem" class="btn btn-primary btn-lg px-5 py-3 rounded-pill">View All Problems <i class="bi bi-arrow-right"></i></a>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <h3 class="fw-bold mb-4 text-center">How evaluation works <i class="bi bi-arrow-repeat ms-2"></i></h3>
        <div class="swiper mySwiper">
            <div class="swiper-wrapper">
                <div class="swiper-slide"><div class="carousel-card p-4 bg-card border rounded-4"><i class="bi bi-file-earmark-code fs-2 text-primary"></i><h5 class="mt-2">1. User uploads code</h5><p class="text-secondary small">C++ source via online editor or file.</p></div></div>
                <div class="swiper-slide"><div class="carousel-card p-4 bg-card border rounded-4"><i class="bi bi-incognito fs-2 text-warning"></i><h5 class="mt-2">2. Hidden test cases</h5><p class="text-secondary small">System runs against private I/O.</p></div></div>
                <div class="swiper-slide"><div class="carousel-card p-4 bg-card border rounded-4"><i class="bi bi-stopwatch fs-2 text-danger"></i><h5 class="mt-2">3. TLE / MLE check</h5><p class="text-secondary small">Time & memory limits enforced.</p></div></div>
                <div class="swiper-slide"><div class="carousel-card p-4 bg-card border rounded-4"><i class="bi bi-check2-circle fs-2 text-success"></i><h5 class="mt-2">4. Instant result</h5><p class="text-secondary small">Verdict shown immediately.</p></div></div>
                <div class="swiper-slide"><div class="carousel-card p-4 bg-card border rounded-4"><i class="bi bi-trophy fs-2 text-warning"></i><h5 class="mt-2">Rank update</h5><p class="text-secondary small">Leaderboard points recalculated.</p></div></div>
            </div>
            <div class="swiper-pagination"></div>
        </div>
    </div>
</section>

<section id="ranking" class="py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-5" data-aos="fade-right">
                <span class="badge-feature">leaderboard</span>
                <h2 class="display-6 fw-bold mt-2">Dynamic ranking & points</h2>
                <p class="text-secondary">Points awarded based on problem difficulty. Live leaderboard tracks solved count.</p>
                <ul class="list-unstyled">
                    <li class="mb-2"><i class="bi bi-check-lg text-primary me-2"></i> Difficulty: Easy (10pt), Medium (30pt), Hard (60pt)</li>
                    <li class="mb-2"><i class="bi bi-check-lg text-primary me-2"></i> Contest rating multiplier</li>
                </ul>
                <a href="/Ranking" class="btn btn-outline-theme mt-3">View Full Ranking <i class="bi bi-arrow-right"></i></a>
            </div>
            <div class="col-lg-7" data-aos="fade-left">
                <div class="card p-4">
                    <table class="table table-borderless align-middle">
                        <thead><tr><th>#</th><th>Coder</th><th>Solved</th><th>Points</th><th>Rating</th></tr></thead>
                        <tbody>
                            <tr><td>🥇</td><td><i class="bi bi-person-circle me-2"></i> Minhaz</td><td>24</td><td><strong>1840</strong></td><td><span class="badge bg-warning text-dark">GM</span></td></tr>
                            <tr><td>🥈</td><td><i class="bi bi-person-circle me-2"></i> Junayed</td><td>21</td><td>1620</td><td><span class="badge bg-info">Expert</span></td></tr>
                            <tr><td>🥉</td><td><i class="bi bi-person-circle me-2"></i> Nazmul</td><td>19</td><td>1480</td><td><span class="badge bg-secondary">Specialist</span></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="compiler" class="py-5">
    <div class="container">
        <div class="card p-5 border-0" style="background: linear-gradient(145deg, var(--bg-card), var(--bg-body));">
            <div class="row">
                <div class="col-md-8">
                    <span class="badge-feature"><i class="bi bi-cpu"></i> compiler API</span>
                    <h2 class="fw-bold mt-2">Integrated with free online compiler API</h2>
                    <p class="text-secondary col-lg-10">Currently supports C++ with hidden test case evaluation.</p>
                    <div class="d-flex gap-3 mt-4 flex-wrap">
                        <span class="badge-custom"><i class="bi bi-check-circle"></i> C++17</span>
                        <span class="badge-custom"><i class="bi bi-clock"></i> Time limit 2s</span>
                        <span class="badge-custom"><i class="bi bi-memory"></i> 256 MB</span>
                    </div>
                    <a href="/Compiler" class="btn btn-primary mt-4 px-5 py-2 rounded-pill">Try Compiler Now</a>
                </div>
                <div class="col-md-4 text-end">
                    <i class="bi bi-terminal-plus" style="font-size: 5rem; color: var(--primary); opacity: 0.7;"></i>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="card p-5 border-0" style="background: var(--primary-light);">
            <div class="row">
                <div class="col-lg-8">
                    <h3 class="fw-bold" style="color: var(--text-primary);">🚀 Future implementations</h3>
                    <div class="row mt-4 g-3">
                        <div class="col-sm-6"><i class="bi bi-check-circle-fill text-primary me-2"></i> Practice mode</div>
                        <div class="col-sm-6"><i class="bi bi-check-circle-fill text-primary me-2"></i> User rating (ELO)</div>
                        <div class="col-sm-6"><i class="bi bi-check-circle-fill text-primary me-2"></i> Plagiarism detection</div>
                        <div class="col-sm-6"><i class="bi bi-check-circle-fill text-primary me-2"></i> Editorial uploads</div>
                    </div>
                </div>
                <div class="col-lg-4 text-end align-self-center">
                    <i class="bi bi-stars" style="font-size: 4rem; opacity: 0.8; color: var(--primary);"></i>
                </div>
            </div>
        </div>
    </div>
</section>

<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
    AOS.init({ duration: 800, once: true });
    new Swiper('.mySwiper', {
    slidesPerView: 1, spaceBetween: 20, loop: true, autoplay: { delay: 2500, disableOnInteraction: false },
    pagination: { el: '.swiper-pagination', clickable: true },
    breakpoints: { 640: { slidesPerView: 2 }, 1024: { slidesPerView: 4 } }
    });
</script>