@model MyMvcApp.Models.Problem
@{
    ViewData["Title"] = @Model.Title + " - Problem Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">

<div class="container py-4">
    <a href="/Problem" class="btn btn-outline-theme mb-4"><i class="bi bi-arrow-left me-2"></i>Back to Problems</a>

    <div class="row">
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-body">
                    <h1 class="fs-1 fw-bold mb-2">@Model.Title</h1>
                    <div class="text-secondary mb-3">Problem #@Model.Id</div>
                    <div class="d-flex flex-wrap gap-2">
                        <span class="badge-custom"><i class="bi bi-clock"></i> @Model.TimeLimit s</span>
                        <span class="badge-custom"><i class="bi bi-memory"></i> @(Model.MemoryLimit / 1024) MB</span>
                        <span class="badge-custom"><i class="bi bi-star-fill text-warning"></i> @Model.Points pts</span>
                        <span class="badge-custom"><i class="bi bi-check-circle-fill text-success"></i> @Model.SolvedCount solved</span>
                        <span class="badge-custom @(Model.Difficulty == 1 ? "difficulty-easy" : Model.Difficulty == 2 ? "difficulty-medium" : "difficulty-hard")"><i class="bi bi-flag"></i> @Model.DifficultyText</span>
                    </div>
                </div>
            </div>

            <div class="card mb-4"><div class="card-header"><i class="bi bi-file-text"></i> Description</div><div class="card-body">@Html.Raw(Model.Description?.Replace("\n", "<br/>"))</div></div>
            <div class="card mb-4"><div class="card-header"><i class="bi bi-arrow-right-circle"></i> Input Format</div><div class="card-body">@Html.Raw(Model.InputFormat?.Replace("\n", "<br/>"))</div></div>
            <div class="card mb-4"><div class="card-header"><i class="bi bi-arrow-left-circle"></i> Output Format</div><div class="card-body">@Html.Raw(Model.OutputFormat?.Replace("\n", "<br/>"))</div></div>
            <div class="card mb-4"><div class="card-header"><i class="bi bi-exclamation-triangle"></i> Constraints</div><div class="card-body">@Html.Raw(Model.Constraints?.Replace("\n", "<br/>"))</div></div>

            <div class="card mb-4">
                <div class="card-header"><i class="bi bi-file-code"></i> Sample Tests</div>
                <div class="card-body">
                    <div class="sample-grid">
                        <div class="sample-box"><div class="sample-title"><i class="bi bi-box-arrow-in-right"></i> Sample Input</div><div class="sample-content"><pre>@Model.SampleInput</pre></div></div>
                        <div class="sample-box"><div class="sample-title"><i class="bi bi-box-arrow-in-left"></i> Sample Output</div><div class="sample-content"><pre>@Model.SampleOutput</pre></div></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card mb-4">
                <div class="card-header"><i class="bi bi-lightning-charge"></i> Actions</div>
                <div class="card-body">
                    <a href="/Compiler?problemId=@Model.Id" class="btn btn-primary w-100 mb-2"><i class="bi bi-code-slash me-2"></i>Solve Problem</a>
                    <a href="/Submissions?problemId=@Model.Id" class="btn btn-outline-primary w-100 mb-2"><i class="bi bi-clock-history me-2"></i>Submission History</a>
                    <button onclick="window.print()" class="btn btn-outline-secondary w-100"><i class="bi bi-printer me-2"></i>Print Problem</button>
                </div>
            </div>

            <div class="card">
                <div class="card-header"><i class="bi bi-graph-up"></i> Statistics</div>
                <div class="card-body">
                    <div class="mb-3"><div class="d-flex justify-content-between mb-1"><span class="text-secondary">Total Submissions</span><span class="fw-bold">@Model.SubmissionCount</span></div></div>
                    <div class="mb-3"><div class="d-flex justify-content-between mb-1"><span class="text-secondary">Accepted</span><span class="fw-bold text-success">@Model.SolvedCount</span></div></div>
                    <div><div class="d-flex justify-content-between mb-1"><span class="text-secondary">Success Rate</span><span class="fw-bold">@Model.SuccessRate%</span></div><div class="progress"><div class="progress-bar bg-success" style="width: @Model.SuccessRate%"></div></div></div>
                </div>
            </div>
        </div>
    </div>
</div>

<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js"></script>
<script>document.addEventListener('DOMContentLoaded',function(){if(typeof renderMathInElement!=='undefined'){renderMathInElement(document.body,{delimiters:[{left:'$$',right:'$$',display:true},{left:'$',right:'$',display:false}],throwOnError:false});}});</script>