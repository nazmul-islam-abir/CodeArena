@model IEnumerable<MyMvcApp.Models.Problem>
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CodeArena · Problems</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-body: #f8fafc;
            --bg-card: #ffffff;
            --text-primary: #0f172a;
            --text-secondary: #334155;
            --border-light: #e2e8f0;
            --navbar-bg: #ffffffcc;
            --footer-bg: #eef2f6;
            --primary: #0284c7;
            --primary-light: #e0f2fe;
            --easy: #10b981;
            --medium: #f59e0b;
            --hard: #ef4444;
        }
        body.dark {
            --bg-body: #0b1120;
            --bg-card: #1e293b;
            --text-primary: #f1f5f9;
            --text-secondary: #cbd5e1;
            --border-light: #334155;
            --navbar-bg: #1e293be6;
            --footer-bg: #0f172a;
            --primary: #38bdf8;
            --primary-light: #1e3a5f;
        }
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-primary);
            transition: all 0.2s ease;
        }
        .navbar {
            background-color: var(--navbar-bg) !important;
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border-light);
        }
        .navbar-brand, .nav-link {
            color: var(--text-primary) !important;
        }
        .theme-toggle {
            background: transparent;
            border: 1px solid var(--border-light);
            color: var(--text-primary);
            padding: 0.4rem 1rem;
            border-radius: 60px;
            cursor: pointer;
        }
        .btn-outline-theme {
            border-color: var(--border-light);
            color: var(--text-primary);
        }
        .btn-outline-theme:hover {
            background-color: var(--primary);
            border-color: var(--primary);
            color: white;
        }
        .card {
            background-color: var(--bg-card);
            border: 1px solid var(--border-light);
            border-radius: 16px;
            transition: transform 0.2s, box-shadow 0.2s;
            cursor: pointer;
        }
        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 30px -10px rgba(0,100,200,0.15);
        }
        .problem-card {
            margin-bottom: 1rem;
        }
        .difficulty-badge {
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
        }
        .difficulty-easy { background-color: rgba(16, 185, 129, 0.2); color: var(--easy); }
        .difficulty-medium { background-color: rgba(245, 158, 11, 0.2); color: var(--medium); }
        .difficulty-hard { background-color: rgba(239, 68, 68, 0.2); color: var(--hard); }
        .category-tag {
            background: var(--primary-light);
            color: var(--primary);
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.85rem;
        }
        .problem-details {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease-out;
        }
        .problem-details.show {
            max-height: 1000px;
            transition: max-height 0.5s ease-in;
        }
        .footer {
            background-color: var(--footer-bg);
            border-top: 1px solid var(--border-light);
        }
        .search-box {
            background-color: var(--bg-card);
            border: 1px solid var(--border-light);
            color: var(--text-primary);
            border-radius: 40px;
            padding: 0.75rem 1.5rem;
        }
        .search-box:focus {
            outline: none;
            border-color: var(--primary);
        }
        .stats-icon {
            color: var(--text-secondary);
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg sticky-top py-3">
        <div class="container">
            <a class="navbar-brand fw-bold fs-3" href="/">
                <i class="bi bi-code-square me-2" style="color: var(--primary);"></i>CodeArena
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-2">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link active fw-bold" href="/Problem">Problems</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Contest">Contests</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Ranking">Ranking</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Compiler">Compiler</a></li>
                </ul>
                <div class="d-flex gap-3 align-items-center">
                    <button class="theme-toggle" id="themeToggle">
                        <i class="bi bi-sun-fill me-1"></i> <span id="themeText">Light</span>
                    </button>
                    <a href="/Auth/Login" class="btn btn-outline-theme px-4 rounded-pill">Log in</a>
                    <a href="/Auth/Signup" class="btn btn-primary px-4 rounded-pill">Sign up</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container py-4">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">
            <div>
                <h2 class="fw-bold"><i class="bi bi-list-task me-2 text-primary"></i>Problem Set</h2>
                <p class="text-secondary">Choose a problem, solve it, and earn points</p>
            </div>
            <div class="d-flex gap-3">
                <input type="text" id="searchInput" class="search-box" placeholder="Search problems..." style="width: 250px;">
                <select id="difficultyFilter" class="form-select" style="width: 150px; background-color: var(--bg-card); color: var(--text-primary); border-color: var(--border-light);">
                    <option value="all">All Difficulties</option>
                    <option value="1">Easy</option>
                    <option value="2">Medium</option>
                    <option value="3">Hard</option>
                </select>
            </div>
        </div>

        <!-- Problems List -->
        <div class="row" id="problemsContainer">
            @foreach (var problem in Model)
            {
                <div class="col-12 problem-card" 
                     data-title="@problem.Title.ToLower()" 
                     data-difficulty="@problem.Difficulty"
                     data-category="@problem.Category.ToLower()">
                    <div class="card p-3" onclick="toggleProblem(@problem.Id)">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-3">
                                <span class="fw-bold text-primary">#@problem.Id</span>
                                <h5 class="mb-0">@problem.Title</h5>
                                <span class="category-tag">@problem.Category</span>
                                <span class="difficulty-badge difficulty-@(problem.Difficulty == 1 ? "easy" : problem.Difficulty == 2 ? "medium" : "hard")">
                                    @problem.DifficultyText
                                </span>
                            </div>
                            <div class="d-flex align-items-center gap-4">
                                <div class="stats-icon">
                                    <i class="bi bi-check-circle-fill text-success"></i> @problem.SolvedCount
                                </div>
                                <div class="stats-icon">
                                    <i class="bi bi-percent"></i> @problem.SuccessRate%
                                </div>
                                <div class="stats-icon">
                                    <i class="bi bi-star-fill text-warning"></i> @problem.Points pts
                                </div>
                                <i class="bi bi-chevron-down" id="chevron-@problem.Id" style="transition: transform 0.3s;"></i>
                            </div>
                        </div>
                        
                        <!-- Problem Details (Hidden by default) -->
                        <div id="problem-@problem.Id" class="problem-details mt-3">
                            <div class="border-top pt-3" style="border-color: var(--border-light) !important;">
                                <div class="row">
                                    <div class="col-md-8">
                                        <h6 class="fw-bold">Description</h6>
                                        <p>@problem.Description</p>
                                        
                                        <h6 class="fw-bold mt-3">Input Format</h6>
                                        <p>@problem.InputFormat</p>
                                        
                                        <h6 class="fw-bold mt-3">Output Format</h6>
                                        <p>@problem.OutputFormat</p>
                                        
                                        <h6 class="fw-bold mt-3">Constraints</h6>
                                        <pre style="background: var(--bg-body); padding: 0.75rem; border-radius: 8px; white-space: pre-wrap;">@problem.Constraints</pre>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="card p-3" style="background: var(--bg-body);">
                                            <h6 class="fw-bold">Sample Input</h6>
                                            <pre class="bg-dark text-white p-2 rounded">@problem.SampleInput</pre>
                                            
                                            <h6 class="fw-bold mt-3">Sample Output</h6>
                                            <pre class="bg-dark text-white p-2 rounded">@problem.SampleOutput</pre>
                                            
                                            <div class="d-flex gap-2 mt-3">
                                                <span class="badge bg-info"><i class="bi bi-clock"></i> @problem.TimeLimit s</span>
                                                <span class="badge bg-secondary"><i class="bi bi-memory"></i> @problem.MemoryLimit MB</span>
                                            </div>
                                            
                                            <a href="/Problem/Solve/@problem.Id" class="btn btn-primary w-100 mt-3">
                                                <i class="bi bi-code-slash me-2"></i>Solve Problem
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <footer class="pt-5 pb-4 mt-5 footer">
        <div class="container">
            <div class="row">
                <div class="col-md-5">
                    <a class="navbar-brand fw-bold fs-3" href="/"><i class="bi bi-code-square me-2 text-primary"></i>CodeArena</a>
                    <p class="text-secondary small col-lg-8 mt-3">Practice coding with our problem set and improve your skills.</p>
                </div>
                <div class="col-md-7">
                    <div class="row">
                        <div class="col-4"><h6 style="color: var(--text-primary);">Platform</h6><ul class="list-unstyled small"><li><a href="/Problem" class="text-secondary text-decoration-none">Problems</a></li><li><a href="/Contest" class="text-secondary text-decoration-none">Contests</a></li><li><a href="/Ranking" class="text-secondary text-decoration-none">Ranking</a></li></ul></div>
                        <div class="col-4"><h6 style="color: var(--text-primary);">Support</h6><ul class="list-unstyled small"><li><a href="#" class="text-secondary text-decoration-none">FAQ</a></li><li><a href="#" class="text-secondary text-decoration-none">Contact</a></li></ul></div>
                        <div class="col-4"><h6 style="color: var(--text-primary);">Team</h6><ul class="list-unstyled small"><li><a href="#" class="text-secondary text-decoration-none">About</a></li><li><a href="#" class="text-secondary text-decoration-none">GitHub</a></li></ul></div>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script>
        // Toggle problem details
        window.toggleProblem = function(id) {
            const details = document.getElementById(`problem-${id}`);
            const chevron = document.getElementById(`chevron-${id}`);
            
            details.classList.toggle('show');
            if (details.classList.contains('show')) {
                chevron.style.transform = 'rotate(180deg)';
            } else {
                chevron.style.transform = 'rotate(0deg)';
            }
        };

        // Search and filter
        document.getElementById('searchInput').addEventListener('input', filterProblems);
        document.getElementById('difficultyFilter').addEventListener('change', filterProblems);

        function filterProblems() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            const difficulty = document.getElementById('difficultyFilter').value;
            
            const problems = document.querySelectorAll('.problem-card');
            
            problems.forEach(problem => {
                const title = problem.dataset.title;
                const problemDifficulty = problem.dataset.difficulty;
                const category = problem.dataset.category;
                
                let matchesSearch = title.includes(searchTerm) || category.includes(searchTerm);
                let matchesDifficulty = difficulty === 'all' || problemDifficulty === difficulty;
                
                if (matchesSearch && matchesDifficulty) {
                    problem.style.display = 'block';
                } else {
                    problem.style.display = 'none';
                }
            });
        }

        // Theme toggle
        const toggleBtn = document.getElementById('themeToggle');
        const themeText = document.getElementById('themeText');
        const body = document.body;

        if (localStorage.getItem('theme') === 'dark') {
            body.classList.add('dark');
            themeText.innerText = 'Dark';
            toggleBtn.innerHTML = '<i class="bi bi-moon-stars-fill me-1"></i> Dark';
        }

        toggleBtn.addEventListener('click', () => {
            body.classList.toggle('dark');
            if (body.classList.contains('dark')) {
                localStorage.setItem('theme', 'dark');
                themeText.innerText = 'Dark';
                toggleBtn.innerHTML = '<i class="bi bi-moon-stars-fill me-1"></i> Dark';
            } else {
                localStorage.setItem('theme', 'light');
                themeText.innerText = 'Light';
                toggleBtn.innerHTML = '<i class="bi bi-sun-fill me-1"></i> Light';
            }
        });
    </script>
</body>
</html>